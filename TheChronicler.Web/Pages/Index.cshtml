@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">
    <i class="bi bi-book" style="font-size: 4rem; color: var(--chr-gold);"></i>
    <h1>The Chronicler</h1>
    <p class="lead">A structured campaign intelligence system for tabletop role-playing games.</p>
    <p>Record sessions. Organize characters, NPCs, locations, and events. Track story arcs. Maintain campaign continuity.</p>
    <div class="mt-4">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-page="/Dashboard/Index" class="btn btn-chronicle btn-lg me-2">
                <i class="bi bi-speedometer2 me-1"></i>Go to Dashboard
            </a>
        }
        else
        {
            <a asp-page="/Account/Register" class="btn btn-chronicle btn-lg me-2">
                <i class="bi bi-person-plus me-1"></i>Get Started
            </a>
            <a asp-page="/Account/Login" class="btn btn-outline-chronicle btn-lg">
                <i class="bi bi-box-arrow-in-right me-1"></i>Login
            </a>
        }
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-journal-text" style="font-size: 2.5rem; color: var(--chr-gold);"></i>
                <h5 class="mt-3">Session Logging</h5>
                <p class="text-muted">Record every session with structured notes, tag characters and locations, and mark key events.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-people" style="font-size: 2.5rem; color: var(--chr-gold);"></i>
                <h5 class="mt-3">Entity Management</h5>
                <p class="text-muted">Organize characters, NPCs, locations, and events with full status tracking and cross-referencing.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-clock-history" style="font-size: 2.5rem; color: var(--chr-gold);"></i>
                <h5 class="mt-3">Timeline View</h5>
                <p class="text-muted">Visualize your campaign chronologically with key event markers and quick session navigation.</p>
            </div>
        </div>
    </div>
</div>
