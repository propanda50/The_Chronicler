@page
@model TheChronicler.Web.Pages.Campaigns.CreateModel
@{
    ViewData["Title"] = "Create Campaign";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Create New Campaign</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Name" class="form-label">Campaign Name</label>
                        <input asp-for="Campaign.Name" class="form-control" placeholder="The Lost Mines of Phandelver" />
                        <span asp-validation-for="Campaign.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Description" class="form-label">Description</label>
                        <textarea asp-for="Campaign.Description" class="form-control" rows="4" placeholder="Describe your campaign world and premise..."></textarea>
                        <span asp-validation-for="Campaign.Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.GameSystem" class="form-label">Game System</label>
                            <input asp-for="Campaign.GameSystem" class="form-control" placeholder="D&D 5e, Pathfinder, etc." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.Status" class="form-label">Status</label>
                            <select asp-for="Campaign.Status" asp-items="Html.GetEnumSelectList<CampaignStatus>()" class="form-select"></select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Campaigns/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Create Campaign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
