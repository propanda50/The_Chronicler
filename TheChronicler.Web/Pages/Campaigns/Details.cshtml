@page "{id:int}"
@model TheChronicler.Web.Pages.Campaigns.DetailsModel
@{
    ViewData["Title"] = Model.Campaign.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-map me-2"></i>@Model.Campaign.Name</h2>
        <span class="badge badge-@Model.Campaign.Status.ToString().ToLower() me-2">@Model.Campaign.Status</span>
        @if (!string.IsNullOrEmpty(Model.Campaign.GameSystem))
        {
            <span class="text-muted"><i class="bi bi-dice-6 me-1"></i>@Model.Campaign.GameSystem</span>
        }
    </div>
    @if (Model.IsGameMaster)
    {
        <div class="d-flex gap-2">
            <a asp-page="/Campaigns/Edit" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-chronicle btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-page="/Campaigns/Delete" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.Campaign.Description))
{
    <div class="card mb-4">
        <div class="card-body">
            <p class="mb-0">@Model.Campaign.Description</p>
        </div>
    </div>
}

<!-- Campaign Navigation Tabs -->
<ul class="nav nav-tabs mb-4" style="border-color: var(--chr-border);">
    <li class="nav-item">
        <a class="nav-link active" style="color: var(--chr-gold); border-color: var(--chr-gold) var(--chr-gold) var(--chr-bg-dark);" href="#">
            <i class="bi bi-grid me-1"></i>Overview
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Sessions/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-journal-text me-1"></i>Sessions (@Model.Campaign.Sessions.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Characters/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-people me-1"></i>Characters (@Model.Campaign.Characters.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Locations/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-geo-alt me-1"></i>Locations (@Model.Campaign.Locations.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Events/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-lightning me-1"></i>Events (@Model.Campaign.Events.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Timeline/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-clock-history me-1"></i>Timeline
        </a>
    </li>
</ul>

<div class="row g-4">
    <!-- Stats -->
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Sessions.Count</div>
            <div class="stat-label">Sessions</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Characters.Count</div>
            <div class="stat-label">Characters</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Locations.Count</div>
            <div class="stat-label">Locations</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Events.Count(e => e.IsKeyEvent)</div>
            <div class="stat-label">Key Events</div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <!-- Recent Sessions -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Recent Sessions</h5>
                @if (Model.IsGameMaster)
                {
                    <a asp-page="/Sessions/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Add
                    </a>
                }
            </div>
            <div class="card-body">
                @if (Model.Campaign.Sessions.Any())
                {
                    @foreach (var session in Model.Campaign.Sessions.OrderByDescending(s => s.SessionDate).Take(5))
                    {
                        <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                            <div>
                                <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="entity-link">
                                    Session @session.SessionNumber: @session.Title
                                </a>
                                <div class="text-muted small">@session.SessionDate.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-3">No sessions yet</div>
                }
            </div>
        </div>
    </div>

    <!-- Members -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people me-2"></i>Members</h5>
                @if (Model.IsGameMaster)
                {
                    <a asp-page="/Campaigns/Members" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-chronicle btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Manage
                    </a>
                }
            </div>
            <div class="card-body">
                <!-- Owner -->
                <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                    <div>
                        <i class="bi bi-person-circle me-2"></i>@Model.Campaign.Owner.DisplayName
                    </div>
                    <span class="badge badge-gm">Owner / GM</span>
                </div>
                @foreach (var member in Model.Campaign.Members.Where(m => m.UserId != Model.Campaign.OwnerId))
                {
                    <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                        <div>
                            <i class="bi bi-person me-2"></i>@member.User.DisplayName
                        </div>
                        <span class="badge badge-@(member.Role == CampaignRole.GameMaster ? "gm" : "player")">@member.Role</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
