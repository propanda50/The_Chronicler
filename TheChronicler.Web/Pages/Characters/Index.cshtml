@page
@model TheChronicler.Web.Pages.Characters.IndexModel
@{
    ViewData["Title"] = "Characters - " + Model.Campaign.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-people me-2"></i>Characters & NPCs</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="entity-link">@Model.Campaign.Name</a>
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <a asp-page="/Characters/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
            <i class="bi bi-plus-lg me-1"></i>New Character
        </a>
    }
</div>

@if (Model.Characters.Any())
{
    <div class="row g-4">
        @foreach (var character in Model.Characters)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="mb-0">
                                <a asp-page="/Characters/Details" asp-route-id="@character.Id" class="entity-link">@character.Name</a>
                            </h5>
                            <span class="badge badge-@character.Status.ToString().ToLower()">@character.Status</span>
                        </div>
                        <div class="mb-2">
                            <span class="badge bg-secondary me-1">@character.Type</span>
                            @if (!string.IsNullOrEmpty(character.Role))
                            {
                                <span class="text-muted small">@character.Role</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(character.Race) || !string.IsNullOrEmpty(character.Class))
                        {
                            <div class="text-muted small mb-2">
                                @character.Race @(!string.IsNullOrEmpty(character.Class) ? $" / {character.Class}" : "")
                            </div>
                        }
                        <p class="card-text text-muted small mb-0">@character.Description.Truncate(100)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-people d-block"></i>
        <h5>No Characters Yet</h5>
        <p>Add characters and NPCs to populate your campaign world.</p>
        @if (Model.IsGameMaster)
        {
            <a asp-page="/Characters/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
                <i class="bi bi-plus-lg me-1"></i>Add First Character
            </a>
        }
    </div>
}
