@page "{id:int}"
@model TheChronicler.Web.Pages.Characters.DetailsModel
@{
    ViewData["Title"] = Model.Character.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-person me-2"></i>@Model.Character.Name</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Character.CampaignId" class="entity-link">@Model.CampaignName</a>
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <div class="d-flex gap-2">
            <a asp-page="/Characters/Edit" asp-route-id="@Model.Character.Id" class="btn btn-outline-chronicle btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-page="/Characters/Delete" asp-route-id="@Model.Character.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="d-flex gap-2 mb-3">
                    <span class="badge badge-@Model.Character.Status.ToString().ToLower()">@Model.Character.Status</span>
                    <span class="badge bg-secondary">@Model.Character.Type</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Character.Race) || !string.IsNullOrEmpty(Model.Character.Class))
                {
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.Character.Race))
                        {
                            <span class="me-3"><strong>Race:</strong> @Model.Character.Race</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Character.Class))
                        {
                            <span class="me-3"><strong>Class:</strong> @Model.Character.Class</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Character.Role))
                {
                    <div class="mb-3">
                        <strong>Role:</strong> @Model.Character.Role
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Character.Description))
                {
                    <h6>Description</h6>
                    <p style="white-space: pre-wrap;">@Model.Character.Description</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Appears In Sessions</h6>
            </div>
            <div class="card-body">
                @if (Model.AppearsInSessions.Any())
                {
                    @foreach (var session in Model.AppearsInSessions)
                    {
                        <div class="p-2 mb-1" style="background: var(--chr-bg-surface); border-radius: 4px;">
                            <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="entity-link">
                                Session @session.SessionNumber: @session.Title
                            </a>
                            <div class="text-muted small">@session.SessionDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted small py-2">Not tagged in any sessions yet</div>
                }
            </div>
        </div>
    </div>
</div>
