@page
@model TheChronicler.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-book" style="font-size: 2.5rem; color: var(--chr-gold);"></i>
                    <h3 class="mt-2" style="color: var(--chr-gold);">Welcome Back</h3>
                    <p class="text-muted">Sign in to your campaign journal</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="chronicler@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <input asp-for="Input.Password" class="form-control" placeholder="Your password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <button type="submit" class="btn btn-chronicle w-100 mb-3">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                    </button>

                    <div class="text-center">
                        <span class="text-muted">Don't have an account?</span>
                        <a asp-page="/Account/Register" class="entity-link">Register here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
