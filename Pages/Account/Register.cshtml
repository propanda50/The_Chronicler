@page
@model TheChronicler.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Chronicler</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
    }
    
    .auth-left {
        flex: 1;
        background: linear-gradient(135deg, #1a1f2e 0%, #0d1117 50%, #1a1520 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px;
        position: relative;
        overflow: hidden;
    }
    
    .auth-left::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(212, 168, 67, 0.05) 0%, transparent 50%);
        animation: pulse-glow 8s ease-in-out infinite;
    }
    
    @@keyframes pulse-glow {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.1); opacity: 0.8; }
    }
    
    .auth-brand {
        position: relative;
        z-index: 1;
        text-align: center;
    }
    
    .auth-brand-logo {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        box-shadow: 0 20px 60px rgba(201, 162, 39, 0.3);
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    
    .auth-brand-logo i {
        font-size: 60px;
        color: #1a1a2e;
    }
    
    .auth-brand h1 {
        color: var(--chr-gold);
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: 2px;
    }
    
    .auth-brand p {
        color: var(--chr-text-muted);
        font-size: 1.2rem;
        max-width: 400px;
    }
    
    .auth-features {
        margin-top: 60px;
        position: relative;
        z-index: 1;
    }
    
    .auth-feature {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 20px;
        color: var(--chr-text-muted);
    }
    
    .auth-feature i {
        color: var(--chr-gold);
        font-size: 1.5rem;
    }
    
    .auth-right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px;
        background: var(--chr-bg-dark);
        overflow-y: auto;
    }
    
    .auth-form-container {
        width: 100%;
        max-width: 500px;
    }
    
    .auth-form-header {
        margin-bottom: 40px;
    }
    
    .auth-form-header h2 {
        color: var(--chr-gold);
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 10px;
    }
    
    .auth-form-header p {
        color: var(--chr-text-muted);
    }
    
    .social-login-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 30px;
    }
    
    .btn-social {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 14px 20px;
        border-radius: 12px;
        font-weight: 500;
        font-size: 1rem;
        transition: all 0.3s ease;
        border: none;
        gap: 12px;
    }
    
    .btn-social:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    
    .btn-google { background: #FFFFFF; color: #3c4043; }
    .btn-google:hover { background: #f8f9fa; }
    .btn-discord { background: #5865F2; color: #FFFFFF; }
    .btn-discord:hover { background: #4752C4; }
    .btn-apple { background: #000000; color: #FFFFFF; border: 1px solid #333; }
    .btn-apple:hover { background: #1a1a1a; }
    
    .divider-text {
        display: flex;
        align-items: center;
        text-align: center;
        color: var(--chr-text-muted);
        margin: 30px 0;
    }
    
    .divider-text::before, .divider-text::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid var(--chr-border);
    }
    
    .divider-text span { padding: 0 20px; font-size: 0.9rem; }
    
    .form-floating {
        margin-bottom: 20px;
    }
    
    .form-floating .form-control,
    .form-floating .form-select {
        background: var(--chr-bg-surface);
        border: 1px solid var(--chr-border);
        color: var(--chr-text);
        padding: 1rem;
        height: auto;
        border-radius: 12px;
    }
    
    .form-floating .form-control:focus,
    .form-floating .form-select:focus {
        border-color: var(--chr-gold);
        box-shadow: 0 0 0 3px rgba(212, 168, 67, 0.15);
    }
    
    .form-floating label {
        color: var(--chr-text-muted);
        padding: 1rem;
    }
    
    .form-floating .form-select {
        padding-top: 1.5rem;
    }
    
    .btn-chronicle {
        width: 100%;
        padding: 16px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 12px;
        margin-top: 10px;
    }
    
    .auth-footer {
        text-align: center;
        margin-top: 30px;
        color: var(--chr-text-muted);
    }
    
    .auth-footer a {
        color: var(--chr-gold);
        text-decoration: none;
        font-weight: 500;
    }
    
    .auth-footer a:hover {
        text-decoration: underline;
    }
    
    .divider-gold {
        border-color: var(--chr-gold);
        opacity: 0.3;
        margin: 30px 0;
    }
    
    @@media (max-width: 992px) {
        .auth-left {
            display: none;
        }
        .auth-right {
            padding: 40px 20px;
        }
    }
</style>

<div class="auth-page">
    <!-- Left Side - Branding -->
    <div class="auth-left">
        <div class="auth-brand">
            <div class="auth-brand-logo">
                <i class="bi bi-book"></i>
            </div>
            <h1>THE CHRONICLER</h1>
            <p>Your Campaign Intelligence System. Start your adventure today!</p>
        </div>
        
        <div class="auth-features">
            <div class="auth-feature">
                <i class="bi bi-journal-text"></i>
                <span>Log sessions with rich formatting</span>
            </div>
            <div class="auth-feature">
                <i class="bi bi-people"></i>
                <span>Manage characters and NPCs</span>
            </div>
            <div class="auth-feature">
                <i class="bi bi-geo-alt"></i>
                <span>Track locations and events</span>
            </div>
            <div class="auth-feature">
                <i class="bi bi-robot"></i>
                <span>AI-powered assistance</span>
            </div>
        </div>
    </div>
    
    <!-- Right Side - Form -->
    <div class="auth-right">
        <div class="auth-form-container">
            <div class="auth-form-header">
                <h2>Join The Chronicler</h2>
                <p>Start your adventure today</p>
            </div>
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <!-- Social Login -->
            <div class="social-login-section">
                <form method="post" asp-page-handler="ExternalLogin">
                    <input type="hidden" name="provider" value="Google" />
                    <button type="submit" class="btn-social btn-google w-100">
                        <svg class="social-icon" viewBox="0 0 24 24" width="24" height="24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span>Sign up with Google</span>
                    </button>
                </form>
                
                <form method="post" asp-page-handler="ExternalLogin">
                    <input type="hidden" name="provider" value="Discord" />
                    <button type="submit" class="btn-social btn-discord w-100">
                        <svg class="social-icon" viewBox="0 0 24 24" width="24" height="24">
                            <path fill="#FFFFFF" d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                        </svg>
                        <span>Sign up with Discord</span>
                    </button>
                </form>
            </div>
            
            <div class="divider-text">
                <span>or register with email</span>
            </div>
            
            <!-- Registration Form -->
            <form method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.DisplayName" class="form-control" placeholder="Display Name" />
                            <label asp-for="Input.DisplayName"><i class="bi bi-person me-2"></i>Display Name</label>
                            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" type="password" placeholder="Password" />
                            <label asp-for="Input.Password"><i class="bi bi-lock me-2"></i>Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="Confirm" />
                            <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock-fill me-2"></i>Confirm</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <hr class="divider-gold" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <select asp-for="Input.PreferredLanguage" class="form-select">
                                <option value="en">English</option>
                                <option value="fr">Français</option>
                                <option value="nl">Nederlands</option>
                                <option value="de">Deutsch</option>
                                <option value="es">Español</option>
                                <option value="it">Italiano</option>
                                <option value="pt">Português</option>
                                <option value="pl">Polski</option>
                                <option value="ru">Русский</option>
                                <option value="ja">日本語</option>
                                <option value="zh">中文</option>
                                <option value="ko">한국어</option>
                                <option value="ar">العربية</option>
                                <option value="tr">Türkçe</option>
                                <option value="cs">Čeština</option>
                                <option value="da">Dansk</option>
                                <option value="el">Ελληνικά</option>
                                <option value="fi">Suomi</option>
                                <option value="he">עברית</option>
                                <option value="hi">हिन्दी</option>
                                <option value="hu">Magyar</option>
                                <option value="id">Bahasa Indonesia</option>
                                <option value="ms">Bahasa Melayu</option>
                                <option value="no">Norsk</option>
                                <option value="ro">Română</option>
                                <option value="sv">Svenska</option>
                                <option value="th">ไทย</option>
                                <option value="uk">Українська</option>
                                <option value="vi">Tiếng Việt</option>
                            </select>
                            <label>Language</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <select asp-for="Input.ExperienceLevel" class="form-select">
                                <option value="">Select...</option>
                                <option value="0">New to TTRPGs</option>
                                <option value="1">Played a bit</option>
                                <option value="2">Experienced player</option>
                            </select>
                            <label>Experience</label>
                        </div>
                    </div>
                </div>
                
                <div class="form-floating mb-3">
                    <select asp-for="Input.PlayStyle" class="form-select">
                        <option value="">Select...</option>
                        <option value="0">I play solo</option>
                        <option value="1">Looking for players</option>
                        <option value="2">Looking for a GM</option>
                        <option value="3">Organizing games</option>
                        <option value="4">Ready to play</option>
                    </select>
                    <label>Play Style</label>
                </div>
                
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-image me-2"></i>Avatar (optional)</label>
                    <input type="file" name="AvatarFile" class="form-control" accept="image/*" />
                </div>
                
                <button type="submit" class="btn btn-chronicle">
                    <i class="bi bi-person-plus me-2"></i>Create Account
                </button>
            </form>
            
            <div class="auth-footer">
                <span>Already have an account?</span>
                <a asp-page="/Account/Login">Sign in</a>
            </div>
        </div>
    </div>
</div>
</body>
</html>