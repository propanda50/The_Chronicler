@page
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Campaigns.CreateModel
@{
    ViewData["Title"] = "Create Campaign";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Create New Campaign</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Name" class="form-label">Campaign Name</label>
                        <div class="input-group">
                            <input asp-for="Campaign.Name" class="form-control" placeholder="The Lost Mines of Phandelver" id="CampaignName" />
                            <button type="button" class="btn btn-outline-secondary" onclick="generateRandomName()">
                                <i class="bi bi-shuffle"></i> Random
                            </button>
                        </div>
                        <span asp-validation-for="Campaign.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Description" class="form-label">Description</label>
                        <textarea asp-for="Campaign.Description" class="form-control" rows="4" placeholder="Describe your campaign world and premise..."></textarea>
                        <span asp-validation-for="Campaign.Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.GameSystem" class="form-label">Game System</label>
                            <input asp-for="Campaign.GameSystem" class="form-control" placeholder="D&D 5e, Pathfinder, etc." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.Status" class="form-label">Status</label>
                            <select asp-for="Campaign.Status" asp-items="Html.GetEnumSelectList<CampaignStatus>()" class="form-select"></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Campaign Cover Image</label>
                            <div class="image-upload-container">
                            <label class="form-label"><i class="bi bi-image me-2"></i>Campaign Cover</label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="upload-option p-4 rounded border border-dashed text-center h-100 d-flex flex-column justify-content-center" style="cursor: pointer; min-height: 120px;" onclick="document.getElementById('coverFile').click()">
                                        <i class="bi bi-cloud-upload fs-1 text-muted mb-2"></i>
                                        <p class="mb-0 fw-medium">Upload Image</p>
                                        <small class="text-muted">PNG, JPG, GIF</small>
                                        <input type="file" id="coverFile" name="CoverFile" accept="image/*" class="d-none" onchange="previewImage(this)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="upload-option p-4 rounded border border-dashed text-center h-100 d-flex flex-column justify-content-center" style="cursor: pointer; min-height: 120px;" onclick="generateAICover()">
                                        <i class="bi bi-magic fs-1 mb-2" style="color: var(--chr-gold);"></i>
                                        <p class="mb-0 fw-medium">Generate with AI</p>
                                        <small class="text-muted">Describe your theme</small>
                                    </div>
                                </div>
                            </div>
                            <div id="aiCoverPrompt" class="mt-3" style="display: none;">
                                <div class="input-group">
                                    <input type="text" id="coverPromptInput" class="form-control" placeholder="Describe your campaign cover (e.g., 'dark fantasy dungeon', 'epic dragon battle')..." />
                                    <button class="btn btn-chronicle" onclick="generateCoverImage()">
                                        <i class="bi bi-magic me-1"></i>Generate
                                    </button>
                                </div>
                            </div>
                            <div id="coverPreview" class="mt-3" style="display: none;">
                                <label class="form-label">Preview</label>
                                <div class="position-relative d-inline-block w-100">
                                    <img id="coverPreviewImg" src="" alt="Cover Preview" class="img-fluid rounded shadow" style="max-height: 300px; width: 100%; object-fit: cover;" />
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2" onclick="removeCoverPreview()">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                                <input type="hidden" id="coverImageUrl" name="CoverImageUrl" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Campaigns/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Create Campaign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generateRandomName() {
            const adjectives = ['Lost', 'Ancient', 'Cursed', 'Forgotten', 'Mystic', 'Dark', 'Golden', 'Shadow', 'Crimson', 'Eternal'];
            const nouns = ['Mines', 'Kingdom', 'Realm', 'Empire', 'Chronicles', 'Saga', 'Tales', 'Quest', 'Journey', 'Legacy'];
            const places = ['Phandelver', 'Waterdeep', 'Neverwinter', 'Baldur\'s Gate', 'Sigil', 'Ravenloft', 'Toril'];
            
            const adj = adjectives[Math.floor(Math.random() * adjectives.length)];
            const noun = nouns[Math.floor(Math.random() * nouns.length)];
            const place = places[Math.floor(Math.random() * places.length)];
            
            const templates = [
                `The ${adj} ${noun} of ${place}`,
                `${adj} ${noun}`,
                `${place}: The ${adj} ${noun}`,
                `Chronicles of ${adj} ${place}`
            ];
            
            document.getElementById('CampaignName').value = templates[Math.floor(Math.random() * templates.length)];
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('coverPreviewImg').src = e.target.result;
                    document.getElementById('coverPreview').style.display = 'block';
                    document.getElementById('coverImageUrl').value = '';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function generateAICover() {
            document.getElementById('aiCoverPrompt').style.display = 'block';
            document.getElementById('coverPromptInput').focus();
        }

        async function generateCoverImage() {
            const prompt = document.getElementById('coverPromptInput').value.trim();
            if (!prompt) {
                alert('Please describe what you want for your campaign cover.');
                return;
            }

            const btn = event.target;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating image...';

            try {
                console.log('Generating image with prompt:', prompt);
                
                const response = await fetch('/AiChat?handler=GenerateImage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ 
                        prompt: prompt,
                        type: 'campaign_cover'
                    })
                });

                const data = await response.json();
                console.log('Server response:', data);
                
                if (data.imageUrl) {
                    const img = document.getElementById('coverPreviewImg');
                    
                    // Show a loading spinner while image loads
                    img.src = '';
                    document.getElementById('coverPreview').style.display = 'block';
                    
                    // Try loading the image with retry logic
                    let attempts = 0;
                    const maxAttempts = 10;
                    
                    const tryLoadImage = () => {
                        return new Promise((resolve) => {
                            img.onload = () => resolve(true);
                            img.onerror = () => resolve(false);
                            // Add timestamp to prevent caching
                            img.src = data.imageUrl + '&t=' + new Date().getTime();
                        });
                    };
                    
                    // Poll until image loads or max attempts reached
                    for (let i = 0; i < maxAttempts; i++) {
                        btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1"></span>Loading... (${i + 1}/${maxAttempts})`;
                        
                        const loaded = await tryLoadImage();
                        if (loaded) {
                            console.log('Image loaded successfully');
                            document.getElementById('coverImageUrl').value = data.imageUrl;
                            document.getElementById('aiCoverPrompt').style.display = 'none';
                            btn.innerHTML = '<i class="bi bi-check me-1"></i>Generated!';
                            setTimeout(() => {
                                btn.innerHTML = '<i class="bi bi-magic me-1"></i>Generate';
                            }, 2000);
                            return;
                        }
                        
                        // Wait 2 seconds before retry
                        await new Promise(r => setTimeout(r, 2000));
                    }
                    
                    // If we get here, image failed to load after all attempts
                    console.error('Image failed to load after multiple attempts');
                    alert('Image is taking longer than expected to generate. Please try again or use a shorter prompt.');
                    document.getElementById('coverPreview').style.display = 'none';
                } else {
                    alert('Failed to generate image: ' + (data.error || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error generating image: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-magic me-1"></i>Generate';
            }
        }

        function removeCoverPreview() {
            document.getElementById('coverPreview').style.display = 'none';
            document.getElementById('coverPreviewImg').src = '';
            document.getElementById('coverImageUrl').value = '';
            document.getElementById('coverFile').value = '';
        }
    </script>
}
