@page "{id:int}"
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Campaigns.MembersModel
@{
    ViewData["Title"] = "Manage Members";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-people me-2"></i>Manage Members - @Model.Campaign.Name</h2>
    <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Campaign
    </a>
</div>

<!-- Add Member -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add Member</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="AddMember">
            <input type="hidden" name="campaignId" value="@Model.Campaign.Id" />
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="player@example.com" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Role</label>
                    <select name="role" class="form-select">
                        <option value="Player">Player</option>
                        <option value="GameMaster">Game Master</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check">
                        <input type="checkbox" name="canAddNotes" value="true" class="form-check-input" id="canAddNotes" />
                        <label class="form-check-label" for="canAddNotes">Can Add Notes</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-chronicle w-100">
                        <i class="bi bi-plus-lg me-1"></i>Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Member List -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Current Members</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Can Add Notes</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="bi bi-person-circle me-1"></i>@Model.Campaign.Owner.DisplayName</td>
                    <td>@Model.Campaign.Owner.Email</td>
                    <td><span class="badge badge-gm">Owner / GM</span></td>
                    <td><i class="bi bi-check-lg text-success"></i></td>
                    <td>@Model.Campaign.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td></td>
                </tr>
                @foreach (var member in Model.Members)
                {
                    <tr>
                        <td><i class="bi bi-person me-1"></i>@member.User.DisplayName</td>
                        <td>@member.User.Email</td>
                        <td><span class="badge badge-@(member.Role == CampaignRole.GameMaster ? "gm" : "player")">@member.Role</span></td>
                        <td>
                            @if (member.CanAddNotes)
                            {
                                <i class="bi bi-check-lg text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-lg text-muted"></i>
                            }
                        </td>
                        <td>@member.JoinedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <form method="post" asp-page-handler="RemoveMember" class="d-inline">
                                <input type="hidden" name="campaignId" value="@Model.Campaign.Id" />
                                <input type="hidden" name="memberId" value="@member.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
