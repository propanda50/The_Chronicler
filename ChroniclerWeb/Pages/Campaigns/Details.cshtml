@page "{id:int}"
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Campaigns.DetailsModel
@{
    ViewData["Title"] = Model.Campaign.Name;
}

<!-- Campaign Hero Section -->
<div class="campaign-hero mb-4">
    @if (!string.IsNullOrEmpty(Model.Campaign.LogoUrl))
    {
        <div class="campaign-cover-container" onclick="openImageModal('@Model.Campaign.LogoUrl')">
            <img src="@Model.Campaign.LogoUrl" alt="@Model.Campaign.Name Cover" class="campaign-cover-image" />
            <div class="campaign-cover-overlay">
                <span class="text-white"><i class="bi bi-zoom-in me-1"></i>Click to enlarge</span>
            </div>
        </div>
    }
    else
    {
        <div class="campaign-cover-placeholder">
            <i class="bi bi-image"></i>
            <span>No cover image</span>
        </div>
    }
    
    <div class="campaign-header-overlay">
        <div class="campaign-title-section">
            <h1 class="campaign-title">
                <i class="bi bi-map me-3"></i>@Model.Campaign.Name
            </h1>
            <div class="campaign-meta">
                <span class="badge badge-@Model.Campaign.Status.ToString().ToLower() fs-6 me-2">@Model.Campaign.Status</span>
                @if (!string.IsNullOrEmpty(Model.Campaign.GameSystem))
                {
                    <span class="text-white-50"><i class="bi bi-dice-6 me-1"></i>@Model.Campaign.GameSystem</span>
                }
            </div>
        </div>
        @if (Model.IsGameMaster)
        {
            <div class="campaign-actions">
                <a asp-page="/Campaigns/Edit" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a asp-page="/Campaigns/Delete" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Delete
                </a>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Campaign.Description))
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title text-warning mb-3"><i class="bi bi-info-circle me-2"></i>Description</h5>
            <p class="mb-0" data-translatable>@Model.Campaign.Description</p>
        </div>
    </div>
}

<style>
    .campaign-hero {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        min-height: 250px;
    }
    
    .campaign-cover-container {
        width: 100%;
        cursor: pointer;
    }
    
    .campaign-cover-image {
        width: 100%;
        height: 250px;
        object-fit: cover;
        display: block;
    }
    
    .campaign-cover-placeholder {
        width: 100%;
        height: 250px;
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--chr-text-muted);
    }
    
        .campaign-cover-placeholder i {
            font-size: 4rem;
            margin-bottom: 10px;
        }
    
    .campaign-cover-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 20px;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .campaign-cover-container:hover .campaign-cover-overlay {
        opacity: 1;
    }
    
    .campaign-header-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 30px;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }
    
    .campaign-title-section {
        flex: 1;
    }
    
    .campaign-title {
        color: white;
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 10px 0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }
    
    .campaign-meta {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .campaign-actions {
        display: flex;
        gap: 10px;
    }
    
    .badge-active {
        background-color: #10b981;
        color: white;
    }
    
    .badge-paused {
        background-color: #f59e0b;
        color: white;
    }
    
    .badge-completed {
        background-color: #6366f1;
        color: white;
    }
    
    @@media (max-width: 768px) {
        .campaign-header-overlay {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }
        
        .campaign-title {
            font-size: 1.8rem;
        }
        
        .campaign-actions {
            width: 100%;
        }
        
            .campaign-actions .btn {
                flex: 1;
            }
    }
</style>

<!-- Campaign Navigation Tabs -->
<ul class="nav nav-tabs mb-4" style="border-color: var(--chr-border);">
    <li class="nav-item">
        <a class="nav-link active" style="color: var(--chr-gold); border-color: var(--chr-gold) var(--chr-gold) var(--chr-bg-dark);" href="#">
            <i class="bi bi-grid me-1"></i>Overview
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Sessions/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-journal-text me-1"></i>Sessions (@Model.Campaign.Sessions.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Characters/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-people me-1"></i>Characters (@Model.Campaign.Characters.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Locations/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-geo-alt me-1"></i>Locations (@Model.Campaign.Locations.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Events/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-lightning me-1"></i>Events (@Model.Campaign.Events.Count)
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Timeline/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-clock-history me-1"></i>Timeline
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/CampaignMap/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-map me-1"></i>Map
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Files/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-folder2-open me-1"></i>Files
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" style="color: var(--chr-text-muted);" asp-page="/Forum/Index" asp-route-campaignId="@Model.Campaign.Id">
            <i class="bi bi-chat-square-text me-1"></i>Forum
        </a>
    </li>
</ul>

<div class="row g-4">
    <!-- Stats -->
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Sessions.Count</div>
            <div class="stat-label">Sessions</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Characters.Count</div>
            <div class="stat-label">Characters</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Locations.Count</div>
            <div class="stat-label">Locations</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-number">@Model.Campaign.Events.Count(e => e.IsKeyEvent)</div>
            <div class="stat-label">Key Events</div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <!-- Recent Sessions -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Recent Sessions</h5>
                @if (Model.IsGameMaster)
                {
                    <a asp-page="/Sessions/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Add
                    </a>
                }
            </div>
            <div class="card-body">
                @if (Model.Campaign.Sessions.Any())
                {
                    @foreach (var session in Model.Campaign.Sessions.OrderByDescending(s => s.SessionDate).Take(5))
                    {
                        <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                            <div>
                                <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="entity-link">
                                    Session @session.SessionNumber: @session.Title
                                </a>
                                <div class="text-muted small">@session.SessionDate.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-3">No sessions yet</div>
                }
            </div>
        </div>
    </div>

    <!-- Members -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people me-2"></i>Members</h5>
                @if (Model.IsGameMaster)
                {
                    <a asp-page="/Campaigns/Members" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-chronicle btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Manage
                    </a>
                }
            </div>
            <div class="card-body">
                <!-- Owner -->
                <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                    <div>
                        <i class="bi bi-person-circle me-2"></i>@Model.Campaign.Owner.DisplayName
                    </div>
                    <span class="badge badge-gm">Owner / GM</span>
                </div>
                @foreach (var member in Model.Campaign.Members.Where(m => m.UserId != Model.Campaign.OwnerId))
                {
                    <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background: var(--chr-bg-surface); border-radius: 4px;">
                        <div>
                            <i class="bi bi-person me-2"></i>@member.User.DisplayName
                        </div>
                        <span class="badge badge-@(member.Role == CampaignRole.GameMaster ? "gm" : "player")">@member.Role</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
