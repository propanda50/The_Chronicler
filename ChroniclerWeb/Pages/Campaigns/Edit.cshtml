@page "{id:int}"
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Campaigns.EditModel
@{
    ViewData["Title"] = "Edit Campaign";
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Edit Campaign</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Campaign.Id" />
                    <input type="hidden" asp-for="Campaign.OwnerId" />
                    <input type="hidden" asp-for="Campaign.CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Name" class="form-label">Campaign Name</label>
                        <input asp-for="Campaign.Name" class="form-control" />
                        <span asp-validation-for="Campaign.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Campaign.Description" class="form-label">Description</label>
                        <textarea asp-for="Campaign.Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.GameSystem" class="form-label">Game System</label>
                            <input asp-for="Campaign.GameSystem" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Campaign.Status" class="form-label">Status</label>
                            <select asp-for="Campaign.Status" asp-items="Html.GetEnumSelectList<CampaignStatus>()" class="form-select"></select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
