@page "{id:int}"
@model ChroniclerWeb.Pages.Locations.DetailsModel
@{
    ViewData["Title"] = Model.Location.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-geo-alt me-2"></i>@Model.Location.Name</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Location.CampaignId" class="entity-link">@Model.CampaignName</a>
            @if (!string.IsNullOrEmpty(Model.Location.Region))
            {
                <span>&mdash; <i class="bi bi-compass me-1"></i>@Model.Location.Region</span>
            }
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <div class="d-flex gap-2">
            <a asp-page="/Locations/Edit" asp-route-id="@Model.Location.Id" class="btn btn-outline-chronicle btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-page="/Locations/Delete" asp-route-id="@Model.Location.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Location.Type))
                {
                    <span class="badge bg-secondary mb-3">@Model.Location.Type</span>
                }
                @if (!string.IsNullOrEmpty(Model.Location.Description))
                {
                    <p style="white-space: pre-wrap;">@Model.Location.Description</p>
                }
                else
                {
                    <p class="text-muted">No description provided.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Visited In Sessions</h6>
            </div>
            <div class="card-body">
                @if (Model.VisitedInSessions.Any())
                {
                    @foreach (var session in Model.VisitedInSessions)
                    {
                        <div class="p-2 mb-1" style="background: var(--chr-bg-surface); border-radius: 4px;">
                            <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="entity-link">
                                Session @session.SessionNumber: @session.Title
                            </a>
                            <div class="text-muted small">@session.SessionDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted small py-2">Not tagged in any sessions yet</div>
                }
            </div>
        </div>
    </div>
</div>
