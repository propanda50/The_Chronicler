@page
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Locations.IndexModel
@{
    ViewData["Title"] = "Locations - " + Model.Campaign.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-geo-alt me-2"></i>Locations</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="entity-link">@Model.Campaign.Name</a>
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <a asp-page="/Locations/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
            <i class="bi bi-plus-lg me-1"></i>New Location
        </a>
    }
</div>

@if (Model.Locations.Any())
{
    <div class="row g-4">
        @foreach (var location in Model.Locations)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="mb-1">
                            <a asp-page="/Locations/Details" asp-route-id="@location.Id" class="entity-link">@location.Name</a>
                        </h5>
                        @if (!string.IsNullOrEmpty(location.Region))
                        {
                            <div class="text-muted small mb-2"><i class="bi bi-compass me-1"></i>@location.Region</div>
                        }
                        @if (!string.IsNullOrEmpty(location.Type))
                        {
                            <span class="badge bg-secondary mb-2">@location.Type</span>
                        }
                        <p class="card-text text-muted small mb-0">@location.Description.Truncate(120)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-geo-alt d-block"></i>
        <h5>No Locations Yet</h5>
        <p>Add locations to map out your campaign world.</p>
        @if (Model.IsGameMaster)
        {
            <a asp-page="/Locations/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
                <i class="bi bi-plus-lg me-1"></i>Add First Location
            </a>
        }
    </div>
}
