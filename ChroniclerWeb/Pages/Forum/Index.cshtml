@page
@model ChroniclerWeb.Pages.Forum.IndexModel
@{
    ViewData["Title"] = "Campaign Forum";
}

<div class="page-header">
    <h2><i class="bi bi-chat-square-text me-2"></i>Campaign Forum</h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.CampaignId" class="entity-link text-info">@Model.CampaignName</a>
    </small>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-header" style="background-color: var(--chr-bg-surface); border-color: var(--chr-border);">
                <h6 class="mb-0"><i class="bi bi-funnel me-1"></i>Categories</h6>
            </div>
            <div class="list-group list-group-flush">
                <a href="?category=&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(string.IsNullOrEmpty(Model.SelectedCategory) ? "active" : "")">
                    <i class="bi bi-list me-1"></i>All Posts
                </a>
                <a href="?category=0&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(Model.SelectedCategory == "0" ? "active" : "")">
                    <i class="bi bi-chat-left me-1"></i>General
                </a>
                <a href="?category=1&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(Model.SelectedCategory == "1" ? "active" : "")">
                    <i class="bi bi-people me-1"></i>Looking for Group
                </a>
                <a href="?category=2&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(Model.SelectedCategory == "2" ? "active" : "")">
                    <i class="bi bi-person-plus me-1"></i>Recruitment
                </a>
                <a href="?category=3&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(Model.SelectedCategory == "3" ? "active" : "")">
                    <i class="bi bi-lightbulb me-1"></i>Tips & Help
                </a>
                <a href="?category=4&campaignId=@Model.CampaignId" class="list-group-item list-group-item-action @(Model.SelectedCategory == "4" ? "active" : "")">
                    <i class="bi bi-chat-left-dots me-1"></i>Discussion
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">
                @if (!string.IsNullOrEmpty(Model.SelectedCategory))
                {
                    <span>@Model.CategoryName</span>
                }
                else
                {
                    <span>All Posts</span>
                }
            </h4>
            <a asp-page="/Forum/Create" asp-route-campaignId="@Model.CampaignId" class="btn btn-chronicle">
                <i class="bi bi-plus-lg me-1"></i>New Post
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.Posts.Count == 0)
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-chat-left-text" style="font-size: 3rem; color: var(--chr-text-muted);"></i>
                    <h5 class="mt-3 text-muted">No posts yet</h5>
                    <p class="text-muted">Be the first to start a discussion!</p>
                    <a asp-page="/Forum/Create" asp-route-campaignId="@Model.CampaignId" class="btn btn-chronicle">
                        <i class="bi bi-plus-lg me-1"></i>Create Post
                    </a>
                </div>
            </div>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                <div class="card mb-3 forum-post-card">
                    <div class="card-body">
                        <span class="badge category-badge me-2">@post.Category</span>
                        <a asp-page="/Forum/Details" asp-route-id="@post.Id" class="text-decoration-none">
                            <h5 class="mb-1">@post.Title</h5>
                        </a>
                        <small class="text-muted">
                            Posted by <strong>@post.AuthorName</strong> on @post.CreatedAt.ToString("MMM dd, yyyy")
                            <span class="ms-2"><i class="bi bi-chat-left me-1"></i>@post.ReplyCount replies</span>
                        </small>
                        <p class="mb-0 mt-2 text-muted">@(post.Content.Length > 200 ? post.Content.Substring(0, 200) + "..." : post.Content)</p>
                    </div>
                </div>
            }
        }
    </div>
</div>
