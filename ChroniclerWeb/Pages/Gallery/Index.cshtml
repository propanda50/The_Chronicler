@page "/campaign/{campaignId}/gallery"
@model TheChronicler.Web.Pages.Gallery.IndexModel
@{
    ViewData["Title"] = "Image Gallery";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-images me-2"></i>Image Gallery</h2>
        <small class="text-muted">@Model.CampaignName</small>
    </div>
    <div>
        <button class="btn btn-chronicle" data-bs-toggle="modal" data-bs-target="#uploadModal">
            <i class="bi bi-upload me-1"></i>Upload Images
        </button>
    </div>
</div>

@* Filter Tabs *@
<ul class="nav nav-tabs mb-4" id="galleryTabs">
    <li class="nav-item">
        <a class="nav-link active" href="#" onclick="filterGallery('all')">All</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" onclick="filterGallery('character')">Characters</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" onclick="filterGallery('token')">Tokens</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" onclick="filterGallery('map')">Maps</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" onclick="filterGallery('other')">Other</a>
    </li>
</ul>

@* Search *@
<div class="mb-4">
    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Search images..." id="searchInput" onkeyup="searchGallery()" />
    </div>
</div>

@* Image Grid *@
<div class="row g-3" id="galleryGrid">
    @foreach (var image in Model.Images)
    {
        <div class="col-md-3 col-sm-4 gallery-item" data-type="@image.Type.ToString().ToLower()" data-name="@image.FileName.ToLower()">
            <div class="gallery-card">
                <div class="gallery-image-container">
                    <img src="@image.Url" alt="@image.FileName" class="gallery-image" onclick="openImageModal('@image.Url', '@image.FileName', '@image.Type')" />
                    <div class="gallery-overlay">
                        <button class="btn btn-sm btn-light" onclick="createToken('@image.Url', '@image.FileName')">
                            <i class="bi bi-person-bounding-box"></i> Make Token
                        </button>
                    </div>
                </div>
                <div class="gallery-info">
                    <small class="text-truncate d-block">@image.FileName</small>
                    <small class="text-muted">@image.Type</small>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Images.Any())
{
    <div class="empty-state">
        <i class="bi bi-images"></i>
        <h5>No images yet</h5>
        <p>Upload images, character portraits, or maps to get started.</p>
    </div>
}

@* Upload Modal *@
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload Images</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
                <div class="modal-body">
                    <input type="hidden" name="CampaignId" value="@Model.CampaignId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Select Images</label>
                        <input type="file" name="Files" class="form-control" accept="image/*" multiple required />
                        <small class="text-muted">Max 10MB per file. Supports JPG, PNG, GIF, WebP</small>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="FileType" class="form-select">
                            <option value="Image">General Image</option>
                            <option value="CharacterPortrait">Character Portrait</option>
                            <option value="Map">Map</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    
                    <div class="upload-preview" id="uploadPreview"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-chronicle">
                        <i class="bi bi-upload me-1"></i>Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Image Preview Modal *@
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalTitle">Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="imageModalImg" src="" alt="" class="img-fluid" style="max-height: 70vh;" />
            </div>
            <div class="modal-footer">
                <a id="imageModalDownload" href="" download class="btn btn-outline-primary">
                    <i class="bi bi-download me-1"></i>Download
                </a>
                <button class="btn btn-outline-secondary" onclick="copyImageUrl()">
                    <i class="bi bi-link-45deg me-1"></i>Copy Link
                </button>
            </div>
        </div>
    </div>
</div>

@* Token Maker Modal *@
<div class="modal fade" id="tokenModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-bounding-box me-2"></i>Token Maker</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Original Image</h6>
                        <div class="token-preview">
                            <img id="tokenSourceImg" src="" class="img-fluid" />
                        </div>
                        <div class="mt-3">
                            <label class="form-label">Zoom</label>
                            <input type="range" class="form-range" id="tokenZoom" min="1" max="2" step="0.1" value="1" onchange="updateTokenPreview()" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Offset X</label>
                            <input type="range" class="form-range" id="tokenOffsetX" min="-100" max="100" value="0" onchange="updateTokenPreview()" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Offset Y</label>
                            <input type="range" class="form-range" id="tokenOffsetY" min="-100" max="100" value="0" onchange="updateTokenPreview()" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Token Preview</h6>
                        <div class="token-result">
                            <canvas id="tokenCanvas" width="200" height="200"></canvas>
                        </div>
                        <div class="mt-3">
                            <label class="form-label">Border Color</label>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm" style="background:#d4a843;width:30px;height:30px;" onclick="setTokenBorder('#d4a843')"></button>
                                <button class="btn btn-sm" style="background:#c94040;width:30px;height:30px;" onclick="setTokenBorder('#c94040')"></button>
                                <button class="btn btn-sm" style="background:#3fb950;width:30px;height:30px;" onclick="setTokenBorder('#3fb950')"></button>
                                <button class="btn btn-sm" style="background:#58a6ff;width:30px;height:30px;" onclick="setTokenBorder('#58a6ff')"></button>
                                <button class="btn btn-sm" style="background:#bc8cff;width:30px;height:30px;" onclick="setTokenBorder('#bc8cff')"></button>
                                <button class="btn btn-sm" style="background:#ffffff;width:30px;height:30px;" onclick="setTokenBorder('#ffffff')"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-chronicle" onclick="saveToken()">
                    <i class="bi bi-save me-1"></i>Save Token
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .gallery-card {
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s;
    }

    .gallery-card:hover {
        border-color: var(--chr-gold);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .gallery-image-container {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
    }

    .gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        cursor: pointer;
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .gallery-card:hover .gallery-overlay {
        opacity: 1;
    }

    .gallery-info {
        padding: 10px 12px;
        background: var(--chr-bg-surface);
    }

    .token-preview, .token-result {
        background: #1a1a2e;
        border-radius: 8px;
        padding: 20px;
        text-align: center;
    }

    .token-result {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
    }

    #tokenCanvas {
        border-radius: 50%;
        border: 4px solid var(--chr-gold);
    }

    .upload-preview img {
        max-width: 100px;
        max-height: 100px;
        object-fit: cover;
        border-radius: 8px;
        margin: 4px;
    }
</style>

@section Scripts {
    <script>
        let currentImageUrl = '';
        let tokenBorderColor = '#d4a843';

        function filterGallery(type) {
            document.querySelectorAll('#galleryTabs .nav-link').forEach(link => link.classList.remove('active'));
            event.target.classList.add('active');
            
            document.querySelectorAll('.gallery-item').forEach(item => {
                if (type === 'all' || item.dataset.type === type) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        function searchGallery() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.gallery-item').forEach(item => {
                const match = item.dataset.name.includes(query);
                item.style.display = match ? 'block' : 'none';
            });
        }

        function openImageModal(url, name, type) {
            document.getElementById('imageModalTitle').textContent = name;
            document.getElementById('imageModalImg').src = url;
            document.getElementById('imageModalDownload').href = url;
            currentImageUrl = url;
            new bootstrap.Modal(document.getElementById('imageModal')).show();
        }

        function copyImageUrl() {
            navigator.clipboard.writeText(currentImageUrl);
            alert('Image URL copied!');
        }

        function createToken(url, name) {
            document.getElementById('tokenSourceImg').src = url;
            document.getElementById('tokenModalTitle')?.remove();
            
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => {
                window.tokenImage = img;
                updateTokenPreview();
            };
            img.src = url;
            
            new bootstrap.Modal(document.getElementById('tokenModal')).show();
        }

        function updateTokenPreview() {
            if (!window.tokenImage) return;
            
            const canvas = document.getElementById('tokenCanvas');
            const ctx = canvas.getContext('2d');
            const zoom = parseFloat(document.getElementById('tokenZoom').value);
            const offsetX = parseFloat(document.getElementById('tokenOffsetX').value);
            const offsetY = parseFloat(document.getElementById('tokenOffsetY').value);
            
            const size = 200;
            const center = size / 2;
            
            ctx.clearRect(0, 0, size, size);
            
            // Create circular clip
            ctx.beginPath();
            ctx.arc(center, center, center - 4, 0, Math.PI * 2);
            ctx.closePath();
            ctx.clip();
            
            // Draw image
            const img = window.tokenImage;
            const imgSize = Math.min(img.width, img.height) * zoom;
            const sx = (img.width - imgSize) / 2;
            const sy = (img.height - imgSize) / 2;
            
            ctx.drawImage(img, sx, sy, imgSize, imgSize, 
                offsetX, offsetY, size + offsetX, size + offsetY);
            
            // Draw border
            ctx.beginPath();
            ctx.arc(center, center, center - 4, 0, Math.PI * 2);
            ctx.strokeStyle = tokenBorderColor;
            ctx.lineWidth = 8;
            ctx.stroke();
        }

        function setTokenBorder(color) {
            tokenBorderColor = color;
            document.getElementById('tokenCanvas').style.borderColor = color;
            updateTokenPreview();
        }

        function saveToken() {
            const canvas = document.getElementById('tokenCanvas');
            const dataUrl = canvas.toDataURL('image/png');
            
            // Create download link
            const link = document.createElement('a');
            link.download = 'token_' + Date.now() + '.png';
            link.href = dataUrl;
            link.click();
            
            bootstrap.Modal.getInstance(document.getElementById('tokenModal')).hide();
        }

        // File upload preview
        document.querySelector('input[type="file"][multiple]')?.addEventListener('change', function(e) {
            const preview = document.getElementById('uploadPreview');
            preview.innerHTML = '';
            
            Array.from(e.target.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
