@page
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Sessions.IndexModel
@{
    ViewData["Title"] = "Sessions - " + Model.Campaign.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-journal-text me-2"></i>Sessions</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="entity-link">@Model.Campaign.Name</a>
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <a asp-page="/Sessions/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
            <i class="bi bi-plus-lg me-1"></i>New Session
        </a>
    }
</div>

@if (Model.Sessions.Any())
{
    <div class="row g-3">
        @foreach (var session in Model.Sessions)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-1">
                                <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="entity-link">
                                    Session @session.SessionNumber: @session.Title
                                </a>
                            </h5>
                            <div class="text-muted small mb-2">
                                <i class="bi bi-calendar me-1"></i>@session.SessionDate.ToString("MMMM dd, yyyy")
                            </div>
                            @if (!string.IsNullOrEmpty(session.Summary))
                            {
                                <p class="mb-1 text-muted">@session.Summary.Truncate(200)</p>
                            }
                            <div class="d-flex gap-3 mt-2">
                                @if (session.SessionCharacters.Any())
                                {
                                    <small class="text-muted"><i class="bi bi-people me-1"></i>@session.SessionCharacters.Count characters</small>
                                }
                                @if (session.SessionLocations.Any())
                                {
                                    <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@session.SessionLocations.Count locations</small>
                                }
                                @if (session.Events.Any())
                                {
                                    <small class="text-muted"><i class="bi bi-lightning me-1"></i>@session.Events.Count events</small>
                                }
                            </div>
                        </div>
                        @if (session.Events.Any(e => e.IsKeyEvent))
                        {
                            <span class="badge badge-key-event"><i class="bi bi-star-fill me-1"></i>Key Event</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-journal-text d-block"></i>
        <h5>No Sessions Yet</h5>
        <p>Record your first session to start building your campaign history.</p>
        @if (Model.IsGameMaster)
        {
            <a asp-page="/Sessions/Create" asp-route-campaignId="@Model.Campaign.Id" class="btn btn-chronicle">
                <i class="bi bi-plus-lg me-1"></i>Create First Session
            </a>
        }
    </div>
}
