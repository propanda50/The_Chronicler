@page
@model ChroniclerWeb.Pages.Sessions.CreateModel
@{
    ViewData["Title"] = "New Session";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>New Session</h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.CampaignId" class="entity-link">@Model.CampaignName</a>
    </small>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Session.CampaignId" value="@Model.CampaignId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Session.Title" class="form-label">Session Title</label>
                            <div class="input-group">
                                <input asp-for="Session.Title" class="form-control" placeholder="The Goblin Ambush" id="SessionTitle" />
                                <button type="button" class="btn btn-outline-secondary" onclick="genTitle()">
                                    <i class="bi bi-shuffle"></i> <span data-t="Random">Random</span>
                                </button>
                            </div>
                            <span asp-validation-for="Session.Title" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Session.SessionNumber" class="form-label">Session #</label>
                            <input asp-for="Session.SessionNumber" class="form-control" value="@Model.NextSessionNumber" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Session.SessionDate" class="form-label">Session Date</label>
                        <input asp-for="Session.SessionDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Session.Summary" class="form-label">Summary</label>
                        <div class="d-flex gap-2 mb-2">
                            <button type="button" class="btn btn-chronicle btn-sm" onclick="genSummary()">
                                <i class="bi bi-magic me-1"></i> <span data-t="Generate Description">Generate Description</span>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="genSummary()" id="regenSumBtn" style="display:none;">
                                <i class="bi bi-arrow-clockwise me-1"></i> <span data-t="Regenerate">Regenerate</span>
                            </button>
                        </div>
                        <textarea asp-for="Session.Summary" class="form-control" rows="2" placeholder="Brief summary of the session..." id="SessionSummary"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Session.Notes" class="form-label">Session Notes</label>
                        <textarea asp-for="Session.Notes" class="form-control notes-editor" rows="12" placeholder="Detailed session notes... Use markdown-style formatting."></textarea>
                        <small class="text-muted">Supports basic text formatting. Write detailed notes about what happened during the session.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Session Image (Optional)</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Upload an image for this session (PNG, JPG, WEBP)</small>
                    </div>

                    @if (Model.AvailableCharacters.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Tag Characters</label>
                            <div class="row g-2">
                                @foreach (var character in Model.AvailableCharacters)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="SelectedCharacterIds" value="@character.Id" id="char_@character.Id" />
                                            <label class="form-check-label" for="char_@character.Id">
                                                @character.Name
                                                <span class="badge badge-@character.Status.ToString().ToLower() ms-1" style="font-size: 0.65rem;">@character.Status</span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.AvailableLocations.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Tag Locations</label>
                            <div class="row g-2">
                                @foreach (var location in Model.AvailableLocations)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="SelectedLocationIds" value="@location.Id" id="loc_@location.Id" />
                                            <label class="form-check-label" for="loc_@location.Id">
                                                @location.Name
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Sessions/Index" asp-route-campaignId="@Model.CampaignId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i><span data-t="Cancel">Cancel</span>
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i><span data-t="New Session">New Session</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            var D={
                en:{adj:['First','Opening','Discovery','Confrontation','Trial','Challenge','Victory','Defeat','Dark','Shadow','Hidden','Lost','Rising','Final','Turning','Awakening'],nouns:['Session','Chapter','Episode','Discovery','Journey','Quest','Trial','Battle','Awakening','Finale','Prologue','Crossroads','Threshold','Revelation','Encounter','Siege','Escape'],stories:['The party gathers at a tavern, discussing recent events. A mysterious stranger enters with urgent news that could change everything.','Dawn breaks as the adventurers journey through dangerous territory. Strange sounds echo from the shadows ahead.','In the depths of ancient ruins, discoveries await. The weight of history presses upon those who dare to explore.','A festival brings joy to the realm, but not all is as it seems. Someone watches from the crowd, waiting.','A storm rages outside as adventurers seek shelter. Locals warn of dark secrets hidden within these walls.']},
                fr:{adj:['Premiere','Decouverte','Confrontation','Epreuve','Defi','Victoire','Defaite','Sombre','Ombre','Cachee','Perdue','Montante','Derniere','Tournante','Eveil'],nouns:['Session','Chapitre','Episode','Decouverte','Voyage','Quete','Epreuve','Bataille','Eveil','Finale','Prologue','Carrefour','Seuil','Revelation','Rencontre','Siege','Fuite'],stories:['Le groupe se reunie dans une taverne, discutant des recents evenements. Un etranger mysterieux entre avec des nouvelles urgentes.','L\'aube se leve alors que les aventuriers voyagent a travers un territoire dangereux. Des bruits etranges provennent de l\'ombre.','Dans les profondeurs de ruines anciennes, des decouvertes attendent. Le poids de l\'histoire pese sur ceux qui osent explorer.','Un festival apporte de la joie au royaume, mais tout n\'est pas ce qu\'il parait. Quelqu\'un observe depuis la foule.','Une tempete fait rage tandis que les aventuriers cherchent un abri. Les habitants mettent en garde contre de sombres secrets.']},
                de:{adj:['Erste','Entdeckung','Konfrontation','Prufung','Herausforderung','Sieg','Niederlage','Dunkle','Schatten','Versteckt','Verloren','Erwachende','Letzte','Wendepunkt','Erweckung'],nouns:['Sitzung','Kapitel','Episode','Entdeckung','Reise','Quest','Prufung','Schlacht','Erweckung','Finale','Prolog','Kreuzweg','Schwelle','Enthullung','Begegnung','Belagerung','Flucht'],stories:['Die Gruppe versammelt sich in einer Taverne und diskutiert ubere kultige Ereignisse. Ein mysterioser Fremder betritt mit dringenden Neuigkeiten.','Die Dammerung bricht an, wahrend die Abenteurer durch gefahrliches Gebiet reisen. Seltsame Gerausche echoen aus dem Schatten.']},
                es:{adj:['Primera','Descubrimiento','Confrontacion','Prueba','Desafio','Victoria','Derrota','Oscura','Sombra','Oculta','Perdida','Final','Despertar'],nouns:['Sesion','Capitulo','Episodio','Descubrimiento','Viaje','Busqueda','Prueba','Batalla','Despertar','Final','Prologo','Cruce','Umbral','Revelacion','Encuentro','Asedio','Fuga'],stories:['El grupo se reune en una taberna, discutiendo eventos recientes. Un extrano misterioso entra con noticias urgentes.','El amanecer rompe mientras los aventureros viajan por territorio peligroso. Sonidos extraños provienen de las sombras.']}
            };
            var lang=function(){return(localStorage.getItem('preferredLanguage')||'en').split('-')[0];};
            var pick=function(a){return a[Math.floor(Math.random()*a.length)];};
            var dict=function(){return D[lang()]||D.en;};

            window.genTitle=function(){
                var d=dict();
                var t=pick(d.adj)+' '+pick(d.nouns);
                document.getElementById('SessionTitle').value=t;
            };

            window.genSummary=function(){
                var d=dict();
                var s=pick(d.stories);
                document.getElementById('SessionSummary').value=s;
                document.getElementById('regenSumBtn').style.display='inline-block';
            };
        })();
    </script>
}