@page "{id:int}"
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Sessions.EditModel
@{
    ViewData["Title"] = Model.IsNotesOnly ? "Edit Notes" : "Edit Session";
}

<div class="page-header">
    <h2>
        <i class="bi bi-pencil me-2"></i>
        @if (Model.IsNotesOnly)
        {
            <span>Edit Notes - Session @Model.Session.SessionNumber</span>
        }
        else
        {
            <span>Edit Session @Model.Session.SessionNumber</span>
        }
    </h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.Session.CampaignId" class="entity-link">@Model.CampaignName</a>
    </small>
</div>

@if (Model.IsNotesOnly)
{
    <div class="alert alert-info mb-3">
        <i class="bi bi-info-circle me-1"></i>You have permission to edit notes only. Other fields are read-only.
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Session.Id" />
                    <input type="hidden" asp-for="Session.CampaignId" />
                    <input type="hidden" asp-for="Session.CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    @if (Model.IsNotesOnly)
                    {
                        <input type="hidden" asp-for="Session.Title" />
                        <input type="hidden" asp-for="Session.SessionNumber" />
                        <input type="hidden" asp-for="Session.SessionDate" />
                        <input type="hidden" asp-for="Session.Summary" />

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Session Title</label>
                                <input type="text" class="form-control" value="@Model.Session.Title" disabled />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Session #</label>
                                <input type="text" class="form-control" value="@Model.Session.SessionNumber" disabled />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Session Date</label>
                            <input type="date" class="form-control" value="@Model.Session.SessionDate.ToString("yyyy-MM-dd")" disabled />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Session.Summary))
                        {
                            <div class="mb-3">
                                <label class="form-label">Summary</label>
                                <textarea class="form-control" rows="2" disabled>@Model.Session.Summary</textarea>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Session.Notes" class="form-label">Session Notes</label>
                            <textarea asp-for="Session.Notes" class="form-control notes-editor" rows="12"></textarea>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Session.Title" class="form-label">Session Title</label>
                                <input asp-for="Session.Title" class="form-control" />
                                <span asp-validation-for="Session.Title" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Session.SessionNumber" class="form-label">Session #</label>
                                <input asp-for="Session.SessionNumber" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Session.SessionDate" class="form-label">Session Date</label>
                            <input asp-for="Session.SessionDate" type="date" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Session.Summary" class="form-label">Summary</label>
                            <textarea asp-for="Session.Summary" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Session.Notes" class="form-label">Session Notes</label>
                            <textarea asp-for="Session.Notes" class="form-control notes-editor" rows="12"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Session Image (Optional)</label>
                            @if (!string.IsNullOrEmpty(Model.Session.ImageData))
                            {
                                <div class="mb-2">
                                    <img src="data:@Model.Session.ImageContentType;base64,@Model.Session.ImageData" alt="Session Image" style="max-width: 200px; max-height: 150px; border-radius: 8px;" />
                                    <div class="form-check mt-1">
                                        <input class="form-check-input" type="checkbox" name="RemoveImage" id="removeImage" />
                                        <label class="form-check-label" for="removeImage">Remove current image</label>
                                    </div>
                                </div>
                            }
                            <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                            <small class="text-muted">Upload a new image to replace the current one (PNG, JPG, WEBP)</small>
                        </div>

                        @if (Model.AvailableCharacters.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label">Tag Characters</label>
                                <div class="row g-2">
                                    @foreach (var character in Model.AvailableCharacters)
                                    {
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="SelectedCharacterIds" value="@character.Id" id="char_@character.Id"
                                                @(Model.SelectedCharacterIds.Contains(character.Id) ? "checked" : "") />
                                                <label class="form-check-label" for="char_@character.Id">@character.Name</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (Model.AvailableLocations.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label">Tag Locations</label>
                                <div class="row g-2">
                                    @foreach (var location in Model.AvailableLocations)
                                    {
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="SelectedLocationIds" value="@location.Id" id="loc_@location.Id"
                                                @(Model.SelectedLocationIds.Contains(location.Id) ? "checked" : "") />
                                                <label class="form-check-label" for="loc_@location.Id">@location.Name</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Sessions/Details" asp-route-id="@Model.Session.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
