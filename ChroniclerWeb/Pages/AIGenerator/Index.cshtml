@page "/ai-generator"
@model ChroniclerWeb.Pages.AIGenerator.IndexModel
@{
    ViewData["Title"] = "AI Generator";
}

<style>
    .ai-generator-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .generator-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .tab-btn {
        padding: 12px 24px;
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 8px;
        color: var(--chr-text-muted);
        cursor: pointer;
        transition: all 0.2s;
    }

    .tab-btn:hover, .tab-btn.active {
        background: var(--chr-gold);
        color: #1a1a2e;
        border-color: var(--chr-gold);
    }

    .generator-panel {
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 16px;
        padding: 30px;
        display: none;
    }

    .generator-panel.active {
        display: block;
    }

    .generator-panel h3 {
        color: var(--chr-gold);
        margin-bottom: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: var(--chr-text-muted);
        margin-bottom: 6px;
        font-size: 0.9rem;
    }

    .form-group select, .form-group input {
        width: 100%;
        padding: 10px 14px;
        background: #1a1a2e;
        border: 1px solid var(--chr-border);
        border-radius: 8px;
        color: white;
    }

    .form-group select:focus, .form-group input:focus {
        border-color: var(--chr-gold);
        outline: none;
    }

    .generate-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        border: none;
        border-radius: 12px;
        color: #1a1a2e;
        font-weight: bold;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .generate-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201, 162, 39, 0.4);
    }

    .generate-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .result-container {
        margin-top: 30px;
        text-align: center;
    }

    .result-image {
        max-width: 512px;
        max-height: 512px;
        border-radius: 16px;
        border: 3px solid var(--chr-gold);
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        animation: fadeIn 0.5s ease;
    }

    .loading-spinner {
        display: none;
        margin: 40px auto;
        text-align: center;
    }

    .loading-spinner.active {
        display: block;
    }

    .spinner {
        width: 60px;
        height: 60px;
        border: 4px solid var(--chr-border);
        border-top-color: var(--chr-gold);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 20px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 20px;
    }

    .action-buttons .btn {
        padding: 10px 24px;
    }

    .free-badge {
        display: inline-block;
        background: #10b981;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: bold;
        margin-left: 10px;
    }

    .preset-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 16px;
        margin-top: 20px;
    }

    .preset-card {
        background: #1a1a2e;
        border: 1px solid var(--chr-border);
        border-radius: 12px;
        padding: 12px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .preset-card:hover {
        border-color: var(--chr-gold);
        transform: translateY(-2px);
    }

    .preset-card img {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
    }

    .preset-card .preset-name {
        margin-top: 8px;
        font-size: 0.85rem;
        color: var(--chr-text-muted);
    }

    .prompt-input {
        width: 100%;
        padding: 12px;
        background: #1a1a2e;
        border: 1px solid var(--chr-border);
        border-radius: 8px;
        color: white;
        resize: vertical;
        min-height: 80px;
    }
</style>

<div class="ai-generator-container">
    <div class="page-header">
        <h2><i class="bi bi-magic me-2"></i>AI Generator <span class="free-badge">100% FREE</span></h2>
        <p class="text-muted">Generate character portraits, logos, and more - unlimited free!</p>
    </div>

    <div class="generator-tabs">
        <button class="tab-btn active" onclick="showTab('portrait')">
            <i class="bi bi-person-circle me-1"></i>Character Portrait
        </button>
        <button class="tab-btn" onclick="showTab('logo')">
            <i class="bi bi-palette me-1"></i>Campaign Logo
        </button>
        <button class="tab-btn" onclick="showTab('custom')">
            <i class="bi bi-image me-1"></i>Custom Image
        </button>
    </div>

    @* Character Portrait Generator *@
    <div class="generator-panel active" id="portraitPanel">
        <h3><i class="bi bi-person-badge me-2"></i>Character Portrait Generator</h3>
        
        <div class="form-row">
            <div class="form-group">
                <label>Race</label>
                <select id="portraitRace">
                    <option value="human">Human</option>
                    <option value="elf">Elf</option>
                    <option value="dwarf">Dwarf</option>
                    <option value="halfling">Halfling</option>
                    <option value="orc">Orc</option>
                    <option value="tiefling">Tiefling</option>
                    <option value="dragonborn">Dragonborn</option>
                    <option value="gnome">Gnome</option>
                    <option value="half-elf">Half-Elf</option>
                    <option value="half-orc">Half-Orc</option>
                </select>
            </div>
            <div class="form-group">
                <label>Class</label>
                <select id="portraitClass">
                    <option value="fighter">Fighter</option>
                    <option value="wizard">Wizard</option>
                    <option value="rogue">Rogue</option>
                    <option value="cleric">Cleric</option>
                    <option value="paladin">Paladin</option>
                    <option value="ranger">Ranger</option>
                    <option value="barbarian">Barbarian</option>
                    <option value="bard">Bard</option>
                    <option value="druid">Druid</option>
                    <option value="monk">Monk</option>
                    <option value="sorcerer">Sorcerer</option>
                    <option value="warlock">Warlock</option>
                </select>
            </div>
            <div class="form-group">
                <label>Gender</label>
                <select id="portraitGender">
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="androgynous">Androgynous</option>
                </select>
            </div>
            <div class="form-group">
                <label>Art Style</label>
                <select id="portraitStyle">
                    <option value="fantasy digital art">Fantasy Digital</option>
                    <option value="oil painting">Oil Painting</option>
                    <option value="anime style">Anime</option>
                    <option value="realistic">Realistic</option>
                    <option value="watercolor">Watercolor</option>
                    <option value="pixel art">Pixel Art</option>
                </select>
            </div>
        </div>
        
        <button class="generate-btn" id="portraitBtn" onclick="generatePortrait()">
            <i class="bi bi-magic me-2"></i>Generate Character Portrait
        </button>
        
        <div class="loading-spinner" id="portraitLoading">
            <div class="spinner"></div>
            <p class="text-muted">Generating your character portrait...</p>
            <p class="text-muted small">Powered by Pollinations.ai (FREE, unlimited)</p>
        </div>
        
        <div class="result-container" id="portraitResult" style="display: none;">
            <img id="portraitImage" class="result-image" alt="Character Portrait" />
            <div class="action-buttons">
                <button class="btn btn-chronicle" onclick="usePortrait()">
                    <i class="bi bi-check-circle me-1"></i>Use for Character
                </button>
                <button class="btn btn-outline-secondary" onclick="downloadImage('portraitImage', 'character-portrait.png')">
                    <i class="bi bi-download me-1"></i>Download
                </button>
                <button class="btn btn-outline-secondary" onclick="generatePortrait()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Regenerate
                </button>
            </div>
        </div>
    </div>

    @* Logo Generator *@
    <div class="generator-panel" id="logoPanel">
        <h3><i class="bi bi-palette me-2"></i>Campaign Logo Generator</h3>
        
        <div class="form-row">
            <div class="form-group" style="grid-column: span 2;">
                <label>Campaign Name</label>
                <input type="text" id="logoName" placeholder="The Lost Mines of Phandelver" />
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-group">
                <label>Theme</label>
                <select id="logoTheme">
                    <option value="medieval fantasy">Medieval Fantasy</option>
                    <option value="dark gothic">Dark Gothic</option>
                    <option value="high fantasy">High Fantasy</option>
                    <option value="steampunk">Steampunk</option>
                    <option value="horror">Horror</option>
                    <option value="sci-fi fantasy">Sci-Fi Fantasy</option>
                    <option value="pirate nautical">Pirate/Nautical</option>
                </select>
            </div>
            <div class="form-group">
                <label>Style</label>
                <select id="logoStyle">
                    <option value="professional vector logo">Professional Logo</option>
                    <option value="hand drawn emblem">Hand-drawn Emblem</option>
                    <option value="simple icon">Simple Icon</option>
                    <option value="ornate crest">Ornate Crest</option>
                </select>
            </div>
        </div>
        
        <button class="generate-btn" id="logoBtn" onclick="generateLogo()">
            <i class="bi bi-magic me-2"></i>Generate Campaign Logo
        </button>
        
        <div class="loading-spinner" id="logoLoading">
            <div class="spinner"></div>
            <p class="text-muted">Creating your campaign logo...</p>
        </div>
        
        <div class="result-container" id="logoResult" style="display: none;">
            <img id="logoImage" class="result-image" alt="Campaign Logo" style="max-height: 300px;" />
            <div class="action-buttons">
                <button class="btn btn-outline-secondary" onclick="downloadImage('logoImage', 'campaign-logo.png')">
                    <i class="bi bi-download me-1"></i>Download
                </button>
                <button class="btn btn-outline-secondary" onclick="generateLogo()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Regenerate
                </button>
            </div>
        </div>
    </div>

    @* Custom Image Generator *@
    <div class="generator-panel" id="customPanel">
        <h3><i class="bi bi-image me-2"></i>Custom Image Generator</h3>
        
        <div class="form-group" style="margin-bottom: 20px;">
            <label>Describe the image you want</label>
            <textarea id="customPrompt" class="prompt-input" placeholder="A mysterious forest with ancient ruins, glowing mushrooms, and a hidden waterfall..."></textarea>
        </div>
        
        <div class="form-row">
            <div class="form-group">
                <label>Width</label>
                <select id="customWidth">
                    <option value="512">512px</option>
                    <option value="768">768px</option>
                    <option value="1024" selected>1024px</option>
                </select>
            </div>
            <div class="form-group">
                <label>Height</label>
                <select id="customHeight">
                    <option value="512">512px</option>
                    <option value="768" selected>768px</option>
                    <option value="1024">1024px</option>
                </select>
            </div>
        </div>
        
        <button class="generate-btn" id="customBtn" onclick="generateCustomImage()">
            <i class="bi bi-magic me-2"></i>Generate Image
        </button>
        
        <div class="loading-spinner" id="customLoading">
            <div class="spinner"></div>
            <p class="text-muted">Creating your image...</p>
        </div>
        
        <div class="result-container" id="customResult" style="display: none;">
            <img id="customImage" class="result-image" alt="Generated Image" />
            <div class="action-buttons">
                <button class="btn btn-outline-secondary" onclick="downloadImage('customImage', 'generated-image.png')">
                    <i class="bi bi-download me-1"></i>Download
                </button>
                <button class="btn btn-outline-secondary" onclick="generateCustomImage()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Regenerate
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.generator-panel').forEach(panel => panel.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tab + 'Panel').classList.add('active');
        }

        async function generatePortrait() {
            const race = document.getElementById('portraitRace').value;
            const charClass = document.getElementById('portraitClass').value;
            const gender = document.getElementById('portraitGender').value;
            const style = document.getElementById('portraitStyle').value;

            const btn = document.getElementById('portraitBtn');
            const loading = document.getElementById('portraitLoading');
            const result = document.getElementById('portraitResult');

            btn.disabled = true;
            loading.classList.add('active');
            result.style.display = 'none';

            try {
                const prompt = `A detailed ${style} portrait of a ${gender} ${race} ${charClass}, fantasy RPG character, dramatic lighting, highly detailed, 4k`;
                const encodedPrompt = encodeURIComponent(prompt);
                const seed = Math.floor(Math.random() * 1000000);
                const imageUrl = `https://image.pollinations.ai/prompt/${encodedPrompt}?width=512&height=512&seed=${seed}&nologo=true`;
                
                // Preload image
                const img = new Image();
                img.onload = () => {
                    document.getElementById('portraitImage').src = imageUrl;
                    loading.classList.remove('active');
                    result.style.display = 'block';
                    btn.disabled = false;
                };
                img.onerror = () => {
                    // Fallback to DiceBear
                    const fallbackUrl = `https://api.dicebear.com/7.x/adventurer/svg?seed=${seed}&backgroundColor=b6e3f4`;
                    document.getElementById('portraitImage').src = fallbackUrl;
                    loading.classList.remove('active');
                    result.style.display = 'block';
                    btn.disabled = false;
                };
                img.src = imageUrl;
            } catch (error) {
                loading.classList.remove('active');
                btn.disabled = false;
                alert('Failed to generate image. Please try again.');
            }
        }

        async function generateLogo() {
            const name = document.getElementById('logoName').value || 'My Campaign';
            const theme = document.getElementById('logoTheme').value;
            const style = document.getElementById('logoStyle').value;

            const btn = document.getElementById('logoBtn');
            const loading = document.getElementById('logoLoading');
            const result = document.getElementById('logoResult');

            btn.disabled = true;
            loading.classList.add('active');
            result.style.display = 'none';

            try {
                const prompt = `${style} for '${name}', ${theme} style, medieval, magical, professional design, vector style`;
                const encodedPrompt = encodeURIComponent(prompt);
                const seed = Math.floor(Math.random() * 1000000);
                const imageUrl = `https://image.pollinations.ai/prompt/${encodedPrompt}?width=512&height=512&seed=${seed}&nologo=true`;
                
                const img = new Image();
                img.onload = () => {
                    document.getElementById('logoImage').src = imageUrl;
                    loading.classList.remove('active');
                    result.style.display = 'block';
                    btn.disabled = false;
                };
                img.src = imageUrl;
            } catch (error) {
                loading.classList.remove('active');
                btn.disabled = false;
                alert('Failed to generate logo. Please try again.');
            }
        }

        async function generateCustomImage() {
            const prompt = document.getElementById('customPrompt').value;
            if (!prompt) {
                alert('Please enter a description for your image.');
                return;
            }

            const width = document.getElementById('customWidth').value;
            const height = document.getElementById('customHeight').value;

            const btn = document.getElementById('customBtn');
            const loading = document.getElementById('customLoading');
            const result = document.getElementById('customResult');

            btn.disabled = true;
            loading.classList.add('active');
            result.style.display = 'none';

            try {
                const encodedPrompt = encodeURIComponent(prompt);
                const seed = Math.floor(Math.random() * 1000000);
                const imageUrl = `https://image.pollinations.ai/prompt/${encodedPrompt}?width=${width}&height=${height}&seed=${seed}&nologo=true`;
                
                const img = new Image();
                img.onload = () => {
                    document.getElementById('customImage').src = imageUrl;
                    loading.classList.remove('active');
                    result.style.display = 'block';
                    btn.disabled = false;
                };
                img.src = imageUrl;
            } catch (error) {
                loading.classList.remove('active');
                btn.disabled = false;
                alert('Failed to generate image. Please try again.');
            }
        }

        function downloadImage(imgId, filename) {
            const img = document.getElementById(imgId);
            const link = document.createElement('a');
            link.download = filename;
            link.href = img.src;
            link.click();
        }

        function usePortrait() {
            const imageUrl = document.getElementById('portraitImage').src;
            // Store for use in character creation
            localStorage.setItem('selectedPortrait', imageUrl);
            alert('Portrait saved! You can use it when creating a character.');
        }
    </script>
}
