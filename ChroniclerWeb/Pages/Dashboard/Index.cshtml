@page
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
    <a asp-page="/Campaigns/Create" class="btn btn-chronicle interactive-link">
        <i class="bi bi-plus-lg me-1"></i>New Campaign
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card card tilt-card">
            <div class="stat-icon"><i class="bi bi-map"></i></div>
            <div class="stat-number">@Model.TotalCampaigns</div>
            <div class="stat-label">Campaigns</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card tilt-card">
            <div class="stat-icon"><i class="bi bi-journal-text"></i></div>
            <div class="stat-number">@Model.TotalSessions</div>
            <div class="stat-label">Sessions</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card tilt-card">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-number">@Model.TotalCharacters</div>
            <div class="stat-label">Characters</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card card tilt-card">
            <div class="stat-icon"><i class="bi bi-geo-alt"></i></div>
            <div class="stat-number">@Model.TotalLocations</div>
            <div class="stat-label">Locations</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-map me-2"></i>Your Campaigns</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Campaigns.Any())
                {
                    @foreach (var campaign in Model.Campaigns)
                    {
                        <a asp-page="/Campaigns/Details" asp-route-id="@campaign.Id" class="campaign-launcher interactive-link text-decoration-none d-block">
                            <div class="campaign-launcher-icon">
                                <i class="bi bi-book"></i>
                            </div>
                            <div class="campaign-launcher-content">
                                <div class="campaign-launcher-title">@campaign.Name</div>
                                <div class="campaign-launcher-meta">
                                    <span class="badge badge-@campaign.Status.ToString().ToLower() me-2">@campaign.Status</span>
                                    <span>@campaign.Sessions.Count sessions</span>
                                </div>
                            </div>
                            <i class="bi bi-chevron-right text-muted"></i>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-state py-5">
                        <i class="bi bi-map d-block"></i>
                        <p>No campaigns yet. Create your first campaign to begin your adventure!</p>
                        <a asp-page="/Campaigns/Create" class="btn btn-chronicle interactive-link">
                            <i class="bi bi-plus-lg me-1"></i>Create Campaign
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Sessions</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentSessions.Any())
                {
                    @foreach (var session in Model.RecentSessions)
                    {
                        <div class="activity-item">
                            <a asp-page="/Sessions/Details" asp-route-id="@session.Id" class="activity-item-title entity-link d-block">
                                @session.Title
                            </a>
                            <div class="activity-item-meta">
                                <i class="bi bi-calendar me-1"></i>@session.SessionDate.ToString("MMM dd, yyyy")
                                &mdash; @session.Campaign.Name
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-journal-text d-block mb-2" style="font-size: 2rem; opacity: 0.5;"></i>
                        <small>No sessions recorded yet</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
