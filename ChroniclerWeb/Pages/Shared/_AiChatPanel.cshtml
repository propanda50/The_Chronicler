@* AI Chat Panel - Draggable, Multilingual, Conversational *@

<style>
    #aiChatContainer {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 420px;
        height: 550px;
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 20px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        display: none;
        flex-direction: column;
        z-index: 9999;
        border: 1px solid rgba(212, 168, 67, 0.3);
        overflow: hidden;
    }
    
    #aiChatContainer.open {
        display: flex;
    }
    
    .ai-chat-header {
        padding: 14px 18px;
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: move;
        user-select: none;
    }
    
    .ai-chat-header h6 {
        margin: 0;
        color: #1a1a2e;
        font-weight: bold;
        font-size: 1rem;
    }
    
    #aiMessages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    #aiMessages::-webkit-scrollbar {
        width: 6px;
    }
    
    #aiMessages::-webkit-scrollbar-thumb {
        background: var(--chr-gold-dim);
        border-radius: 3px;
    }
    
    .ai-message {
        padding: 12px 16px;
        border-radius: 16px;
        max-width: 85%;
        line-height: 1.5;
        animation: fadeIn 0.3s ease;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .ai-message.bot {
        background: rgba(22, 33, 62, 0.9);
        color: #e0e0e0;
        border-bottom-left-radius: 4px;
        align-self: flex-start;
        border: 1px solid rgba(255,255,255,0.05);
    }
    
    .ai-message.user {
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        color: #1a1a2e;
        border-bottom-right-radius: 4px;
        align-self: flex-end;
        font-weight: 500;
    }
    
    .ai-message.image-message {
        padding: 8px;
        background: rgba(22, 33, 62, 0.9);
        border: 1px solid rgba(212, 168, 67, 0.3);
    }
    
    .ai-message.image-message img {
        width: 100%;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s;
    }
    
    .ai-message.image-message img:hover {
        transform: scale(1.02);
    }
    
    .ai-typing {
        display: flex;
        gap: 6px;
        padding: 12px 16px;
        background: rgba(22, 33, 62, 0.9);
        border-radius: 16px;
        align-self: flex-start;
    }
    
    .ai-typing span {
        width: 8px;
        height: 8px;
        background: var(--chr-gold);
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }
    
    .ai-typing span:nth-child(2) { animation-delay: 0.2s; }
    .ai-typing span:nth-child(3) { animation-delay: 0.4s; }
    
    @@keyframes typing {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30% { transform: translateY(-8px); opacity: 1; }
    }
    
    .ai-input-area {
        padding: 12px;
        background: rgba(13, 17, 23, 0.5);
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .ai-input-wrapper {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    
    #aiInput {
        flex: 1;
        border: 1px solid rgba(212, 168, 67, 0.3);
        background: rgba(22, 33, 62, 0.8);
        color: white;
        border-radius: 25px;
        padding: 10px 16px;
        font-size: 0.9rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    
    #aiInput:focus {
        outline: none;
        border-color: var(--chr-gold);
        box-shadow: 0 0 0 3px rgba(212, 168, 67, 0.15);
    }
    
    #aiInput::placeholder {
        color: rgba(255,255,255,0.4);
    }
    
    .ai-send-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        border: none;
        color: #1a1a2e;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .ai-send-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 4px 15px rgba(212, 168, 67, 0.4);
    }
    
    .ai-toggle-btn {
        position: fixed;
        bottom: 25px;
        right: 25px;
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--chr-gold), #c9a227);
        border: none;
        color: #1a1a2e;
        font-size: 28px;
        cursor: grab;
        box-shadow: 0 6px 25px rgba(212, 168, 67, 0.5);
        z-index: 9998;
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .ai-toggle-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 8px 35px rgba(212, 168, 67, 0.6);
    }
    
    .ai-toggle-btn:active {
        cursor: grabbing;
    }
    
    .ai-toggle-btn.active {
        opacity: 0;
        pointer-events: none;
    }
    
    .ai-quick-actions {
        display: flex;
        gap: 6px;
        padding: 8px 12px;
        overflow-x: auto;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    
    .ai-quick-btn {
        padding: 6px 12px;
        background: rgba(212, 168, 67, 0.15);
        border: 1px solid rgba(212, 168, 67, 0.3);
        border-radius: 20px;
        color: var(--chr-gold);
        font-size: 0.75rem;
        white-space: nowrap;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .ai-quick-btn:hover {
        background: rgba(212, 168, 67, 0.3);
        transform: translateY(-1px);
    }
    
    .ai-close-btn {
        background: transparent;
        border: none;
        color: #1a1a2e;
        font-size: 1.2rem;
        cursor: pointer;
        padding: 4px;
        border-radius: 50%;
        transition: background 0.2s;
    }
    
    .ai-close-btn:hover {
        background: rgba(0,0,0,0.1);
    }
    
    /* Image Modal */
    .ai-image-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10000;
    }
    
    .ai-image-modal.open {
        display: flex;
    }
    
    .ai-image-modal img {
        max-width: 90%;
        max-height: 90%;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    
    .ai-modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255,255,255,0.1);
        border: none;
        color: white;
        font-size: 2rem;
        cursor: pointer;
        border-radius: 50%;
        width: 50px;
        height: 50px;
    }
</style>

<button class="ai-toggle-btn" id="aiToggleBtn" onclick="toggleAiChat()">
    <i class="bi bi-robot"></i>
</button>

<div id="aiChatContainer">
    <div class="ai-chat-header" id="aiChatHeader">
        <h6><i class="bi bi-robot me-2"></i>AI Assistant</h6>
        <button class="ai-close-btn" onclick="toggleAiChat()">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    
    <div class="ai-quick-actions">
        <button class="ai-quick-btn" onclick="sendQuickMessage('Aide-moi')">Aide</button>
        <button class="ai-quick-btn" onclick="sendQuickMessage('Créer un personnage')">Personnage</button>
        <button class="ai-quick-btn" onclick="sendQuickMessage('Créer une campagne')">Campagne</button>
        <button class="ai-quick-btn" onclick="sendQuickMessage('Générer un nom')">Nom</button>
        <button class="ai-quick-btn" onclick="sendQuickMessage('Générer une image')">Image</button>
    </div>
    
    <div id="aiMessages">
        <div class="ai-message bot">
            Salut! Je suis ton assistant IA. Je parle toutes les langues! Tu peux me demander de créer des personnages, des campagnes, des lieux, générer des images, ou juste discuter. Comment puis-je t'aider?
        </div>
    </div>
    
    <div class="ai-input-area">
        <div class="ai-input-wrapper">
            <input type="text" id="aiInput" placeholder="Tape ton message..." onkeypress="if(event.key==='Enter')sendAiMessage()" />
            <button class="ai-send-btn" onclick="sendAiMessage()">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="ai-image-modal" id="imageModal" onclick="closeImageModal()">
    <button class="ai-modal-close">&times;</button>
    <img id="modalImage" src="" alt="Generated Image" />
</div>

<script>
    // Draggable functionality
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;
    let isDraggingButton = false;
    
    // Make the AI toggle button draggable
    const aiToggleBtn = document.getElementById('aiToggleBtn');
    const aiChatContainer = document.getElementById('aiChatContainer');
    const aiChatHeader = document.getElementById('aiChatHeader');
    
    // Button dragging
    aiToggleBtn.addEventListener('mousedown', (e) => {
        isDraggingButton = true;
        const rect = aiToggleBtn.getBoundingClientRect();
        dragOffsetX = e.clientX - rect.left;
        dragOffsetY = e.clientY - rect.top;
        aiToggleBtn.style.transition = 'none';
    });
    
    // Window dragging
    aiChatHeader.addEventListener('mousedown', (e) => {
        if (e.target.closest('.ai-close-btn')) return;
        isDragging = true;
        const rect = aiChatContainer.getBoundingClientRect();
        dragOffsetX = e.clientX - rect.left;
        dragOffsetY = e.clientY - rect.top;
        aiChatContainer.style.transition = 'none';
    });
    
    document.addEventListener('mousemove', (e) => {
        if (isDraggingButton) {
            const newX = e.clientX - dragOffsetX;
            const newY = e.clientY - dragOffsetY;
            
            // Keep within viewport
            const maxX = window.innerWidth - aiToggleBtn.offsetWidth;
            const maxY = window.innerHeight - aiToggleBtn.offsetHeight;
            
            aiToggleBtn.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
            aiToggleBtn.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
            aiToggleBtn.style.right = 'auto';
            aiToggleBtn.style.bottom = 'auto';
        }
        
        if (isDragging) {
            const newX = e.clientX - dragOffsetX;
            const newY = e.clientY - dragOffsetY;
            
            // Keep within viewport
            const maxX = window.innerWidth - aiChatContainer.offsetWidth;
            const maxY = window.innerHeight - aiChatContainer.offsetHeight;
            
            aiChatContainer.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
            aiChatContainer.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
            aiChatContainer.style.right = 'auto';
            aiChatContainer.style.bottom = 'auto';
        }
    });
    
    document.addEventListener('mouseup', () => {
        isDragging = false;
        isDraggingButton = false;
        aiToggleBtn.style.transition = 'transform 0.2s, box-shadow 0.2s';
        aiChatContainer.style.transition = '';
    });
    
    function toggleAiChat() {
        const container = document.getElementById('aiChatContainer');
        const btn = document.getElementById('aiToggleBtn');
        container.classList.toggle('open');
        btn.classList.toggle('active');
        
        if (container.classList.contains('open')) {
            document.getElementById('aiInput').focus();
        }
    }
    
    function sendQuickMessage(message) {
        document.getElementById('aiInput').value = message;
        sendAiMessage();
    }
    
    function addAiMessage(content, isUser = false, isImage = false, imageUrl = '') {
        const messagesDiv = document.getElementById('aiMessages');
        const msgDiv = document.createElement('div');
        
        if (isImage) {
            msgDiv.className = 'ai-message image-message bot';
            msgDiv.innerHTML = `
                <img src="${imageUrl}" alt="Generated Image" onclick="openImageModal('${imageUrl}')" />
                <p style="margin: 8px 0 0; font-size: 0.85rem; color: var(--chr-text-muted);">${content}</p>
            `;
        } else {
            msgDiv.className = `ai-message ${isUser ? 'user' : 'bot'}`;
            msgDiv.textContent = content;
        }
        
        messagesDiv.appendChild(msgDiv);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
    
    function showTypingIndicator() {
        const messagesDiv = document.getElementById('aiMessages');
        const typingDiv = document.createElement('div');
        typingDiv.className = 'ai-typing';
        typingDiv.id = 'typingIndicator';
        typingDiv.innerHTML = '<span></span><span></span><span></span>';
        messagesDiv.appendChild(typingDiv);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
    
    function hideTypingIndicator() {
        const indicator = document.getElementById('typingIndicator');
        if (indicator) indicator.remove();
    }
    
    async function sendAiMessage() {
        const input = document.getElementById('aiInput');
        const message = input.value.trim();
        if (!message) return;
        
        addAiMessage(message, true);
        input.value = '';
        showTypingIndicator();
        
        try {
            const response = await fetch('/AiChat?handler=SendMessage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ message: message })
            });
            
            const data = await response.json();
            hideTypingIndicator();
            
            // Check if response contains an image URL
            if (data.imageUrl) {
                addAiMessage(data.response, false, true, data.imageUrl);
            } else {
                addAiMessage(data.response);
            }
            
            // Execute action if any
            if (data.action) {
                executeAiAction(data.action, data.data);
            }
        } catch (error) {
            hideTypingIndicator();
            addAiMessage("Désolé, j'ai rencontré une erreur. Réessaye.");
        }
    }
    
    function executeAiAction(action, data) {
        switch (action) {
            case 'createCharacter':
                window.location.href = `/Characters/Create?campaignId=${data.campaignId}&name=${encodeURIComponent(data.name)}&race=${encodeURIComponent(data.race)}&class=${encodeURIComponent(data.class)}`;
                break;
            case 'createLocation':
                window.location.href = `/Locations/Create?campaignId=${data.campaignId}&name=${encodeURIComponent(data.name)}`;
                break;
            case 'createCampaign':
                window.location.href = '/Campaigns/Create';
                break;
            case 'navigate':
                window.location.href = data.url;
                break;
            case 'generateImage':
                // Image is already displayed in chat
                break;
        }
    }
    
    function openImageModal(imageUrl) {
        event.stopPropagation();
        document.getElementById('modalImage').src = imageUrl;
        document.getElementById('imageModal').classList.add('open');
    }
    
    function closeImageModal() {
        document.getElementById('imageModal').classList.remove('open');
    }
    
    // Close modal with Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeImageModal();
        }
    });
</script>