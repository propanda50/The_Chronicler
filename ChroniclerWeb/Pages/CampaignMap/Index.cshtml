@page "{campaignId:int}"
@model ChroniclerWeb.Pages.CampaignMap.IndexModel
@{
    ViewData["Title"] = "Campaign Map";
}

<style>
    .map-layout { display: grid; grid-template-columns: minmax(0, 1fr) 340px; gap: 16px; }
    .map-main { position: relative; }
    .map-container { border-radius: 12px; border: 2px solid var(--chr-gold); background: #111827; }

    .map-image-wrapper {
        position: relative;
        width: 100%;
        height: 80vh;
        overflow: auto;
        border-radius: 10px;
    }

    #mapImage {
        display: block;
        height: auto;
        cursor: crosshair;
    }

    .map-pin {
        position: absolute;
        transform: translate(-50%, -50%);
        z-index: 50;
        cursor: pointer;
    }

    .map-pin-inner {
        width: 16px;
        height: 16px;
        background: #ffcc33;
        border: 2px solid #ffffff;
        border-radius: 50%;
        box-shadow: 0 0 0 2px rgba(0,0,0,0.35);
        position: relative;
    }

    .map-pin-inner::after {
        content: "";
        position: absolute;
        inset: -8px;
        border-radius: 50%;
        border: 2px solid rgba(255, 204, 51, 0.45);
        opacity: 0;
    }

    .map-pin.active .map-pin-inner {
        background: #ffd966;
        box-shadow: 0 0 0 3px rgba(255, 217, 102, 0.35), 0 0 18px rgba(255, 217, 102, 0.8);
    }

    .map-pin.active .map-pin-inner::after {
        opacity: 1;
        animation: pinPulse 1.2s infinite ease-out;
    }

    @@keyframes pinPulse {
        0% { transform: scale(0.8); opacity: 0.9; }
        100% { transform: scale(1.8); opacity: 0; }
    }

    .pin-hover-label {
        position: absolute;
        bottom: 22px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.85);
        color: #fff;
        font-size: 0.78rem;
        padding: 4px 8px;
        border-radius: 999px;
        white-space: nowrap;
        display: none;
        pointer-events: none;
        z-index: 100;
    }

    .map-pin:hover .pin-hover-label { display: block; }

    .pin-popup {
        position: absolute;
        top: 24px;
        left: 24px;
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-gold);
        border-radius: 8px;
        padding: 12px;
        min-width: 220px;
        max-width: 280px;
        z-index: 60;
        display: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.45);
    }

    .pin-popup.visible { display: block; }
    .pin-popup.popup-left { left: auto; right: 24px; }
    .pin-popup.popup-top { top: auto; bottom: 24px; }
    .pin-popup h6 { margin-bottom: 4px; color: var(--chr-gold); }
    .pin-popup .pin-type { font-size: 0.8rem; color: var(--chr-text-muted); margin-bottom: 8px; }
    .pin-popup-actions { display: flex; gap: 8px; margin-top: 8px; }

    .map-topbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 12px; }
    .map-sidebar { max-height: 80vh; overflow-y: auto; border: 1px solid var(--chr-border); border-radius: 12px; background: var(--chr-bg-card); padding: 12px; }
    .pin-card { border: 1px solid var(--chr-border); border-radius: 10px; padding: 10px; margin-bottom: 10px; background: var(--chr-bg-surface); cursor: pointer; }
    .pin-card.active { border-color: var(--chr-gold); box-shadow: 0 0 0 2px rgba(212,168,67,.15); }
    .temp-marker { opacity: 0.6; }
    .no-map-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 500px; color: var(--chr-text-muted); padding: 40px; }
    @@media (max-width: 991px) { .map-layout { grid-template-columns: 1fr; } .map-image-wrapper, .map-sidebar { height: auto; max-height: none; } }
</style>

<div class="page-header">
    <h2><i class="bi bi-map me-2" data-t="Campaign Map">Campaign Map</i></h2>
    <small class="text-muted">@Model.CampaignName</small>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="campaignId" value="@Model.CampaignId" />
<input type="hidden" id="editingLocationId" value="" />

<div class="map-layout">
    <div class="map-main">
        <div class="map-topbar">
            <div><strong data-t="Interactive Map">Interactive Map</strong><br /><small class="text-muted" data-t="Click on map to place pin">Click on map to place pin</small></div>
            <div style="min-width:240px;"><input type="file" id="mapUpload" class="form-control form-control-sm" accept="image/*" onchange="uploadMap()" data-t-placeholder="Upload map" /></div>
        </div>
        <div class="map-container">
            @if (!string.IsNullOrEmpty(Model.MapUrl))
            {
                <div class="map-image-wrapper" id="mapImageWrapper">
                    <img src="@Model.MapUrl" alt="Campaign Map" id="mapImage" onclick="handleMapClick(event)" />
                    @foreach (var loc in Model.Locations)
                    {
                        if (loc.MapX.HasValue && loc.MapY.HasValue)
                        {
                            <div class="map-pin" style="left:@(loc.MapX.Value)%; top:@(loc.MapY.Value)%;" data-id="@loc.Id" data-name="@loc.Name" data-description="@(loc.Description ?? "")" data-type="@(loc.Type ?? "")" data-x="@loc.MapX" data-y="@loc.MapY" onclick="togglePinPopup(event, @loc.Id)">
                                <div class="map-pin-inner"></div>
                                <div class="pin-hover-label">@loc.Name</div>
                                <div class="pin-popup" id="popup-@loc.Id">
                                    <h6>@loc.Name</h6>
                                    @if (!string.IsNullOrWhiteSpace(loc.Type)) { <div class="pin-type">@loc.Type</div> }
                                    @if (!string.IsNullOrWhiteSpace(loc.Description)) { <p style="font-size:0.9rem;margin-bottom:8px;">@loc.Description</p> }
                                    else { <p class="text-muted" style="font-size:0.9rem;margin-bottom:8px;">Aucune description.</p> }
                                    <div class="pin-popup-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation(); editLocationFromPin(@loc.Id)"><i class="bi bi-pencil"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); deleteLocation(@loc.Id)"><i class="bi bi-trash"></i></button>
                                        <a class="btn btn-sm btn-outline-secondary" href="/Locations/Details?id=@loc.Id"><i class="bi bi-box-arrow-up-right"></i></a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="no-map-placeholder">
                    <i class="bi bi-map" style="font-size:4rem;"></i>
                    <h5 data-t="No map">No map</h5>
                    <p data-t="Upload a map to get started">Upload a map to get started</p>
                </div>
            }
        </div>
    </div>
    <aside class="map-sidebar">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0" id="editorTitle" data-t="Add pin">Add pin</h5>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="cancelLocation()">Reset</button>
        </div>
        <p class="text-muted small mb-2" data-t="Click on the map first">Click on the map, then fill in the fields.</p>
        <div class="mb-2"><input type="text" id="newLocationName" class="form-control form-control-sm" placeholder="Name" data-t-placeholder="Name" /></div>
        <div class="mb-2"><input type="text" id="newLocationType" class="form-control form-control-sm" placeholder="Type" data-t-placeholder="Type" /></div>
        <div class="mb-2"><textarea id="newLocationDesc" class="form-control form-control-sm" rows="4" placeholder="Description" data-t-placeholder="Description"></textarea></div>
        <div class="d-grid gap-2 mb-3">
            <button type="button" class="btn btn-chronicle btn-sm" onclick="saveLocation()" id="saveLocBtn" disabled data-t="Save">Save</button>
            <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteEditingLocation()" id="deleteLocBtn" style="display:none;" data-t="Delete this pin">Delete this pin</button>
        </div>
        <hr />
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0" data-t="Pin list">Pin list</h5>
            <span class="text-muted small">@Model.Locations.Count</span>
        </div>
        <input type="text" id="pinSearch" class="form-control form-control-sm mb-3" placeholder="Search" data-t-placeholder="Search" oninput="filterPins()" />
        <div id="pinList">
            @foreach (var loc in Model.Locations)
            {
                <div class="pin-card" data-pin-card="@loc.Id" data-pin-name="@loc.Name.ToLowerInvariant()" onclick="focusPin(@loc.Id)">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <div>
                            <strong>@loc.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(loc.Type)) { <div class="small text-muted">@loc.Type</div> }
                        </div>
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation(); editLocationFromPin(@loc.Id)"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); deleteLocation(@loc.Id)"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(loc.Description)) { <div class="small text-muted mt-2">@loc.Description</div> }
                </div>
            }
        </div>
    </aside>
</div>

@section Scripts {
<script>
    let selectedPerc = null;

    function getRequestVerificationToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    function handleMapClick(event) {
        const img = document.getElementById('mapImage');
        if (!img) return;
        const rect = img.getBoundingClientRect();
        const scrollLeft = document.getElementById('mapImageWrapper').scrollLeft;
        const scrollTop = document.getElementById('mapImageWrapper').scrollTop;
        const pixelX = event.clientX - rect.left + scrollLeft;
        const pixelY = event.clientY - rect.top + scrollTop;
        const percX = (pixelX / img.naturalWidth) * 100;
        const percY = (pixelY / img.naturalHeight) * 100;
        selectedPerc = { x: percX, y: percY };
        document.getElementById('saveLocBtn').disabled = false;
        const oldTemp = document.getElementById('tempMarker');
        if (oldTemp) oldTemp.remove();
        const wrapper = document.getElementById('mapImageWrapper');
        const marker = document.createElement('div');
        marker.className = 'map-pin temp-marker';
        marker.id = 'tempMarker';
        marker.style.left = pixelX + 'px';
        marker.style.top = pixelY + 'px';
        marker.innerHTML = '<div class="map-pin-inner"></div>';
        wrapper.appendChild(marker);
    }

    function togglePinPopup(event, id) {
        event.stopPropagation();
        const popup = document.getElementById('popup-' + id);
        const pin = document.querySelector('.map-pin[data-id="' + id + '"]');
        if (!popup || !pin) return;

        const wasVisible = popup.classList.contains('visible');
        document.querySelectorAll('.pin-popup.visible').forEach(p => p.classList.remove('visible', 'popup-left', 'popup-top'));
        document.querySelectorAll('.map-pin.active').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.pin-card.active').forEach(c => c.classList.remove('active'));

        if (wasVisible) return;

        pin.classList.add('active');
        const card = document.querySelector('[data-pin-card="' + id + '"]');
        if (card) card.classList.add('active');
        popup.classList.add('visible');
    }

    function focusPin(id) {
        const wrapper = document.getElementById('mapImageWrapper');
        const pin = document.querySelector('.map-pin[data-id="' + id + '"]');
        const popup = document.getElementById('popup-' + id);
        if (!wrapper || !pin) return;

        document.querySelectorAll('.pin-popup.visible').forEach(p => p.classList.remove('visible', 'popup-left', 'popup-top'));
        document.querySelectorAll('.map-pin.active').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.pin-card.active').forEach(c => c.classList.remove('active'));

        pin.classList.add('active');
        const card = document.querySelector('[data-pin-card="' + id + '"]');
        if (card) card.classList.add('active');

        const pinRect = pin.getBoundingClientRect();
        const wrapperRect = wrapper.getBoundingClientRect();
        const scrollX = pinRect.left - wrapperRect.left + wrapper.scrollLeft - wrapper.clientWidth / 2 + pinRect.width / 2;
        const scrollY = pinRect.top - wrapperRect.top + wrapper.scrollTop - wrapper.clientHeight / 2 + pinRect.height / 2;

        wrapper.scrollTo({ left: Math.max(scrollX, 0), top: Math.max(scrollY, 0), behavior: 'smooth' });

        setTimeout(() => {
            if (popup) popup.classList.add('visible');
        }, 300);
    }

    function editLocationFromPin(id) {
        const pin = document.querySelector('.map-pin[data-id="' + id + '"]');
        if (!pin) return;
        document.getElementById('editingLocationId').value = id;
        document.getElementById('newLocationName').value = pin.dataset.name || '';
        document.getElementById('newLocationType').value = pin.dataset.type || '';
        document.getElementById('newLocationDesc').value = pin.dataset.description || '';
        document.getElementById('editorTitle').textContent = window.UIDictionary && window.UIDictionary[localStorage.getItem('preferredLanguage') || 'en'] ? (window.UIDictionary[localStorage.getItem('preferredLanguage') || 'en']['Edit pin'] || 'Edit pin') : 'Edit pin';
        document.getElementById('deleteLocBtn').style.display = '';
        document.getElementById('saveLocBtn').disabled = false;
        selectedPerc = { x: parseFloat(pin.dataset.x), y: parseFloat(pin.dataset.y) };
        focusPin(id);
    }

    async function saveLocation() {
        const campaignId = parseInt(document.getElementById('campaignId').value);
        const editingId = document.getElementById('editingLocationId').value;
        const name = document.getElementById('newLocationName').value.trim();
        if (!name) { alert(window.Translator ? window.Translator.translate('Enter a name') : 'Enter a name'); return; }
        if (!selectedPerc) { alert(window.Translator ? window.Translator.translate('Click on the map first') : 'Click on the map first'); return; }

        const isEdit = !!editingId;
        const url = isEdit ? '/CampaignMap/' + campaignId + '?handler=UpdateLocation' : '/CampaignMap/' + campaignId + '?handler=AddLocation';
        const payload = {
            id: isEdit ? parseInt(editingId) : 0, campaignId: campaignId, name: name,
            description: document.getElementById('newLocationDesc').value.trim(),
            type: document.getElementById('newLocationType').value.trim(),
            region: '', mapX: selectedPerc.x, mapY: selectedPerc.y
        };
        try {
            const resp = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getRequestVerificationToken() }, body: JSON.stringify(payload) });
            const data = await resp.json();
            if (!data.success) { alert(data.error || (window.Translator ? window.Translator.translate('Error') : 'Error')); return; }
            location.reload();
        } catch (err) { alert((window.Translator ? window.Translator.translate('Error') : 'Error') + ': ' + err.message); }
    }

    async function deleteLocation(id) {
        if (!confirm(window.Translator ? window.Translator.translate('Delete this pin?') : 'Delete this pin?')) return;
        const campaignId = parseInt(document.getElementById('campaignId').value);
        try {
            const resp = await fetch('/CampaignMap/' + campaignId + '?handler=DeleteLocation', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getRequestVerificationToken() }, body: JSON.stringify({ id: id, campaignId: campaignId }) });
            const data = await resp.json();
            if (!data.success) { alert(data.error || (window.Translator ? window.Translator.translate('Error') : 'Error')); return; }
            location.reload();
        } catch (err) { alert((window.Translator ? window.Translator.translate('Error') : 'Error') + ': ' + err.message); }
    }

    function deleteEditingLocation() {
        const id = document.getElementById('editingLocationId').value;
        if (id) deleteLocation(parseInt(id));
    }

    function cancelLocation() {
        selectedPerc = null;
        document.getElementById('editingLocationId').value = '';
        document.getElementById('newLocationName').value = '';
        document.getElementById('newLocationType').value = '';
        document.getElementById('newLocationDesc').value = '';
        const title = document.getElementById('editorTitle');
        title.textContent = title.getAttribute('data-t') || 'Add pin';
        document.getElementById('saveLocBtn').disabled = true;
        document.getElementById('deleteLocBtn').style.display = 'none';
        const oldTemp = document.getElementById('tempMarker');
        if (oldTemp) oldTemp.remove();
        document.querySelectorAll('.pin-popup.visible').forEach(p => p.classList.remove('visible', 'popup-left', 'popup-top'));
        document.querySelectorAll('.map-pin.active').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.pin-card.active').forEach(c => c.classList.remove('active'));
    }

    function filterPins() {
        const term = document.getElementById('pinSearch').value.trim().toLowerCase();
        document.querySelectorAll('[data-pin-card]').forEach(c => { c.style.display = !term || (c.getAttribute('data-pin-name') || '').includes(term) ? '' : 'none'; });
    }

    async function uploadMap() {
        const file = document.getElementById('mapUpload').files[0];
        if (!file) return;
        const campaignId = document.getElementById('campaignId').value;
        const fd = new FormData();
        fd.append('file', file);
        fd.append('campaignId', campaignId);
        try {
            const resp = await fetch('/CampaignMap/' + campaignId + '?handler=UploadMap', { method: 'POST', body: fd });
            const data = await resp.json();
            if (!data.success) { alert(data.error || (window.Translator ? window.Translator.translate('Upload error') : 'Upload error')); return; }
            location.reload();
        } catch (err) { alert((window.Translator ? window.Translator.translate('Error') : 'Error') + ': ' + err.message); }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const img = document.getElementById('mapImage');
        if (!img) return;

        function convertPins() {
            const w = img.naturalWidth;
            const h = img.naturalHeight;
            if (!w || !h) return;
            document.querySelectorAll('.map-pin').forEach(pin => {
                const px = parseFloat(pin.dataset.x) / 100 * w;
                const py = parseFloat(pin.dataset.y) / 100 * h;
                pin.style.left = px + 'px';
                pin.style.top = py + 'px';
            });
        }

        if (img.complete && img.naturalWidth) {
            convertPins();
        } else {
            img.onload = convertPins;
        }
    });

    document.addEventListener('click', function (e) {
        if (!e.target.closest('.map-pin') && !e.target.closest('.pin-card') && !e.target.closest('.pin-popup')) {
            document.querySelectorAll('.pin-popup.visible').forEach(p => p.classList.remove('visible', 'popup-left', 'popup-top'));
            document.querySelectorAll('.map-pin.active').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.pin-card.active').forEach(c => c.classList.remove('active'));
        }
    });
</script>
}
