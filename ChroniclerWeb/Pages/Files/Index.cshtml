@page
@model ChroniclerWeb.Pages.Files.IndexModel
@{
    ViewData["Title"] = "File Library";
}

<div class="page-header">
    <h2><i class="bi bi-folder2-open me-2"></i>File Library</h2>
    <small class="text-muted">@Model.CampaignName</small>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Upload Form -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Upload File</h5>
    </div>
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            <input type="hidden" name="CampaignId" value="@Model.CampaignId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">File</label>
                    <input type="file" name="File" class="form-control" accept="*/*" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select name="FileType" class="form-select">
                        <option value="Document">Document</option>
                        <option value="Image">Image</option>
                        <option value="Audio">Audio</option>
                        <option value="Map">Map</option>
                        <option value="CharacterPortrait">Character Portrait</option>
                        <option value="CampaignLogo">Campaign Logo</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Description</label>
                    <input type="text" name="Description" class="form-control" placeholder="Optional context note" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label">Link to Character</label>
                    <select name="CharacterId" class="form-select">
                        <option value="">-- None --</option>
                        @foreach (var c in Model.AvailableCharacters)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Link to Location</label>
                    <select name="LocationId" class="form-select">
                        <option value="">-- None --</option>
                        @foreach (var l in Model.AvailableLocations)
                        {
                            <option value="@l.Id">@l.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Link to Event</label>
                    <select name="EventId" class="form-select">
                        <option value="">-- None --</option>
                        @foreach (var e in Model.AvailableEvents)
                        {
                            <option value="@e.Id">@e.Title</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Link to Session</label>
                    <select name="SessionId" class="form-select">
                        <option value="">-- None --</option>
                        @foreach (var s in Model.AvailableSessions)
                        {
                            <option value="@s.Id">Session @s.SessionNumber: @s.Title</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-chronicle">
                    <i class="bi bi-upload me-1"></i>Upload
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-auto">
                <label class="form-label mb-0 small">Filter by type:</label>
            </div>
            <div class="col-md-3">
                <select id="filterType" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">All Types</option>
                    <option value="Document">Document</option>
                    <option value="Image">Image</option>
                    <option value="Audio">Audio</option>
                    <option value="Map">Map</option>
                    <option value="CharacterPortrait">Character Portrait</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label mb-0 small">Linked to:</label>
            </div>
            <div class="col-md-3">
                <select id="filterEntity" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">All</option>
                    <option value="character">Character</option>
                    <option value="location">Location</option>
                    <option value="event">Event</option>
                    <option value="session">Session</option>
                    <option value="forumpost">Forum Post</option>
                    <option value="none">Unlinked</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="text" id="filterSearch" class="form-control form-control-sm" placeholder="Search filename..." oninput="applyFilters()" />
            </div>
        </div>
    </div>
</div>

<!-- File Cards -->
<div class="row" id="fileGrid">
    @foreach (var file in Model.Files)
    {
        <div class="col-md-4 mb-3 file-card"
             data-type="@file.Type"
             data-has-character="@(file.CharacterId.HasValue ? "yes" : "no")"
             data-has-location="@(file.LocationId.HasValue ? "yes" : "no")"
             data-has-event="@(file.EventId.HasValue ? "yes" : "no")"
             data-has-session="@(file.SessionId.HasValue ? "yes" : "no")"
             data-has-forumpost="@(file.ForumPostId.HasValue ? "yes" : "no")"
             data-name="@file.FileName.ToLower()">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">
                        @if (file.ContentType.StartsWith("image/"))
                        {
                            <i class="bi bi-image me-1 text-success"></i>
                        }
                        else if (file.ContentType.StartsWith("audio/"))
                        {
                            <i class="bi bi-music-note-beamed me-1 text-info"></i>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark me-1 text-warning"></i>
                        }
                        @file.FileName
                    </h6>

                    <div class="mb-2">
                        <span class="badge bg-secondary">@file.Type</span>
                        <small class="text-muted ms-1">@((file.FileSize / 1024).ToString("N0")) KB</small>
                        <small class="text-muted ms-1">@file.UploadedAt.ToString("MMM dd, yyyy")</small>
                    </div>

                    @if (!string.IsNullOrEmpty(file.Description))
                    {
                        <p class="small text-muted mb-1">@file.Description</p>
                    }

                    <!-- Linked entities -->
                    <div class="mb-2">
                        @if (file.Character != null)
                        {
                            <a href="/Characters/Details?id=@file.CharacterId" class="badge bg-primary text-decoration-none me-1"><i class="bi bi-person me-1"></i>@file.Character.Name</a>
                        }
                        @if (file.Location != null)
                        {
                            <a href="/Locations/Details?id=@file.LocationId" class="badge bg-success text-decoration-none me-1"><i class="bi bi-geo-alt me-1"></i>@file.Location.Name</a>
                        }
                        @if (file.Event != null)
                        {
                            <a href="/Events/Details?id=@file.EventId" class="badge bg-warning text-dark text-decoration-none me-1"><i class="bi bi-lightning me-1"></i>@file.Event.Title</a>
                        }
                        @if (file.Session != null)
                        {
                            <a href="/Sessions/Details?id=@file.SessionId" class="badge bg-info text-decoration-none me-1"><i class="bi bi-journal me-1"></i>Session @file.Session.SessionNumber</a>
                        }
                        @if (file.ForumPost != null)
                        {
                            <a href="/Forum/Details?id=@file.ForumPostId" class="badge bg-secondary text-decoration-none me-1"><i class="bi bi-chat me-1"></i>@file.ForumPost.Title</a>
                        }
                    </div>

                    <!-- Preview -->
                    @if (file.ContentType.StartsWith("image/"))
                    {
                        <img src="@file.Url" class="img-fluid rounded mb-2" alt="@file.FileName" style="max-height:150px;object-fit:cover;width:100%;" onclick="openImageModal('@file.Url')" style="cursor:pointer;" />
                    }
                    else if (file.ContentType.StartsWith("audio/"))
                    {
                        <audio controls class="w-100 mb-2">
                            <source src="@file.Url" type="@file.ContentType" />
                        </audio>
                    }

                    <!-- Actions -->
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <small class="text-muted">By @(file.UploadedBy?.DisplayName ?? "Unknown")</small>
                        <div>
                            <a href="@file.Url" download="@file.FileName" class="btn btn-sm btn-outline-primary me-1" title="Download">
                                <i class="bi bi-download"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline">
                                <input type="hidden" name="fileId" value="@file.Id" />
                                <input type="hidden" name="campaignId" value="@Model.CampaignId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this file?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Files.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No files uploaded yet.
    </div>
}

<script>
    function applyFilters() {
        const typeFilter = document.getElementById('filterType').value;
        const entityFilter = document.getElementById('filterEntity').value;
        const searchFilter = document.getElementById('filterSearch').value.toLowerCase();

        document.querySelectorAll('.file-card').forEach(card => {
            let show = true;

            if (typeFilter && card.dataset.type !== typeFilter) show = false;

            if (entityFilter) {
                if (entityFilter === 'none') {
                    if (card.dataset.hasCharacter === 'yes' || card.dataset.hasLocation === 'yes' ||
                        card.dataset.hasEvent === 'yes' || card.dataset.hasSession === 'yes' ||
                        card.dataset.hasForumpost === 'yes') show = false;
                } else {
                    const key = 'has' + entityFilter.charAt(0).toUpperCase() + entityFilter.slice(1);
                    if (card.dataset[key] !== 'yes') show = false;
                }
            }

            if (searchFilter && !card.dataset.name.includes(searchFilter)) show = false;

            card.style.display = show ? '' : 'none';
        });
    }
</script>
