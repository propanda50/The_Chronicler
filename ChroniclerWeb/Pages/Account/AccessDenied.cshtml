@page
@model ChroniclerWeb.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="text-center py-5">
    <i class="bi bi-shield-lock" style="font-size: 4rem; color: var(--chr-red);"></i>
    <h2 class="mt-3">Access Denied</h2>
    <p class="text-muted">You do not have permission to access this resource.</p>
    <a asp-page="/Dashboard/Index" class="btn btn-chronicle mt-3">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>
