@page
@model TheChronicler.Web.Pages.Account.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<style>
    .settings-page {
        display: flex;
        gap: 30px;
        min-height: calc(100vh - 200px);
    }
    
    .settings-sidebar {
        width: 250px;
        flex-shrink: 0;
    }
    
    .settings-nav {
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 12px;
        padding: 10px;
        position: sticky;
        top: 20px;
    }
    
    .settings-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        color: var(--chr-text-muted);
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s;
        margin-bottom: 4px;
    }
    
.settings-nav-item:hover {
    background: rgba(139, 92, 246, 0.1);
    color: var(--chr-primary);
}

.settings-nav-item.active {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(124, 58, 237, 0.1));
    color: var(--chr-primary);
    border: 1px solid rgba(139, 92, 246, 0.3);
}
    
    .settings-content {
        flex: 1;
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 12px;
        padding: 30px;
    }
    
    .settings-section {
        margin-bottom: 30px;
    }
    
    .settings-section:last-child {
        margin-bottom: 0;
    }
    
    .settings-section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--chr-gold);
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--chr-border);
    }
    
    .profile-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--chr-gold);
    }
    
    .profile-avatar-placeholder {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid var(--chr-gold);
    }
    
    .profile-avatar-placeholder i {
        font-size: 3rem;
        color: var(--chr-gold);
    }
    
    .profile-info h3 {
        margin: 0 0 5px 0;
        color: var(--chr-text);
    }
    
    .profile-info p {
        margin: 0;
        color: var(--chr-text-muted);
    }
    
    .account-age {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(212, 168, 67, 0.1);
        padding: 8px 16px;
        border-radius: 20px;
        margin-top: 10px;
        font-size: 0.9rem;
    }
    
    .account-age i {
        color: var(--chr-gold);
    }
    
    .stat-card {
        background: var(--chr-bg-surface);
        border: 1px solid var(--chr-border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
    }
    
    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--chr-gold);
    }
    
    .stat-label {
        color: var(--chr-text-muted);
        font-size: 0.9rem;
    }
    
    @@media (max-width: 768px) {
        .settings-page {
            flex-direction: column;
        }
        
        .settings-sidebar {
            width: 100%;
        }
        
        .settings-nav {
            position: static;
            display: flex;
            overflow-x: auto;
            gap: 8px;
        }
        
        .settings-nav-item {
            white-space: nowrap;
            margin-bottom: 0;
        }
        
        .avatar-options {
            display: flex;
            gap: 20px;
            margin-top: 15px;
        }
        
        .avatar-upload, .avatar-defaults {
            flex: 1;
        }
        
        .avatar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }
        
        .avatar-option {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            border: 2px solid transparent;
            border-radius: 8px;
            padding: 8px;
            transition: all 0.2s;
        }
        
        .avatar-option:hover {
            border-color: var(--chr-primary);
            background-color: rgba(139, 92, 246, 0.05);
        }
        
        .avatar-option input[type="radio"] {
            margin: 0;
            width: 16px;
            height: 16px;
        }
        
        .avatar-preview {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid var(--chr-border);
            margin-top: 5px;
        }
        
        .avatar-option input[type="radio"]:checked + .avatar-preview {
            border-color: var(--chr-primary);
            transform: scale(1.1);
        }
    }
</style>

<div class="page-header mb-4">
    <h2><i class="bi bi-gear me-2"></i>Settings</h2>
</div>

<div class="settings-page">
    <!-- Sidebar Navigation -->
    <div class="settings-sidebar">
        <nav class="settings-nav">
            <a href="#profile" class="settings-nav-item active" onclick="showSection('profile')">
                <i class="bi bi-person"></i>
                <span>Profile</span>
            </a>
            <a href="#preferences" class="settings-nav-item" onclick="showSection('preferences')">
                <i class="bi bi-sliders"></i>
                <span>Preferences</span>
            </a>
            <a href="#security" class="settings-nav-item" onclick="showSection('security')">
                <i class="bi bi-shield-lock"></i>
                <span>Security</span>
            </a>
            <a href="#notifications" class="settings-nav-item" onclick="showSection('notifications')">
                <i class="bi bi-bell"></i>
                <span>Notifications</span>
            </a>
        </nav>
    </div>
    
    <!-- Content -->
    <div class="settings-content">
        <!-- Profile Section -->
        <div id="profile-section" class="settings-section">
            <h3 class="settings-section-title"><i class="bi bi-person me-2"></i>Profile</h3>
            
            <div class="profile-header">
                @{
                    var avatarSrc = !string.IsNullOrEmpty(Model.CurrentUser.AvatarUrl) 
                        ? Model.CurrentUser.AvatarUrl 
                        : (!string.IsNullOrEmpty(Model.CurrentUser.AvatarData) 
                            ? $"data:{Model.CurrentUser.AvatarContentType ?? "image/jpeg"};base64,{Model.CurrentUser.AvatarData}" 
                            : null);
                }
                @if (!string.IsNullOrEmpty(avatarSrc))
                {
                    <img src="@avatarSrc" alt="Profile" class="profile-avatar" />
                }
                else
                {
                    <div class="profile-avatar-placeholder">
                        <i class="bi bi-person"></i>
                    </div>
                }
                <div class="profile-info">
                    <h3>@Model.CurrentUser.DisplayName</h3>
                    <p>@Model.CurrentUser.Email</p>
                    <div class="account-age">
                        <i class="bi bi-calendar3"></i>
                        <span>Member for @Model.GetAccountAge()</span>
                    </div>
                </div>
            </div>
            
            <form method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Display Name</label>
                        <input type="text" class="form-control" value="@Model.CurrentUser.DisplayName" name="DisplayName" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="@Model.CurrentUser.Email" readonly />
                    </div>
                </div>
                
<div class="mb-3">
    <label class="form-label">Profile Picture</label>
    <div class="avatar-options">
        <div class="avatar-upload">
            <label class="form-label">Upload Custom Avatar</label>
            <input type="file" class="form-control" name="AvatarFile" accept="image/*" />
        </div>
        
        <div class="avatar-defaults">
            <label class="form-label">Choose Default Avatar</label>
            <div class="avatar-grid">
                @foreach (var avatar in Model.DefaultAvatars.Take(12)) // Show first 12
                {
                    <label class="avatar-option">
                        <input type="radio" name="SelectedAvatar" value="@avatar" />
                        <img src="@avatar" alt="Avatar" class="avatar-preview" />
                    </label>
                }
            </div>
            <div class="avatar-grid">
                @foreach (var avatar in Model.DefaultAvatars.Skip(12).Take(12)) // Show next 12
                {
                    <label class="avatar-option">
                        <input type="radio" name="SelectedAvatar" value="@avatar" />
                        <img src="@avatar" alt="Avatar" class="avatar-preview" />
                    </label>
                }
            </div>
            <div class="avatar-grid">
                @foreach (var avatar in Model.DefaultAvatars.Skip(24)) // Show remaining 6
                {
                    <label class="avatar-option">
                        <input type="radio" name="SelectedAvatar" value="@avatar" />
                        <img src="@avatar" alt="Avatar" class="avatar-preview" />
                    </label>
                }
            </div>
        </div>
    </div>
</div>
                
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-chronicle">
                        <i class="bi bi-check-lg me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
        
        <!-- Preferences Section -->
        <div id="preferences-section" class="settings-section" style="display: none;">
            <h3 class="settings-section-title"><i class="bi bi-sliders me-2"></i>Preferences</h3>
            
            <form method="post" asp-page-handler="UpdatePreferences">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Language</label>
                        <select class="form-select" name="Language">
                            <option value="en" selected="@(Model.CurrentUser.PreferredLanguage == "en")">English</option>
                            <option value="fr" selected="@(Model.CurrentUser.PreferredLanguage == "fr")">Français</option>
                            <option value="nl" selected="@(Model.CurrentUser.PreferredLanguage == "nl")">Nederlands</option>
                            <option value="de" selected="@(Model.CurrentUser.PreferredLanguage == "de")">Deutsch</option>
                            <option value="es" selected="@(Model.CurrentUser.PreferredLanguage == "es")">Español</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Theme</label>
                        <select class="form-select" name="Theme">
                            <option value="dark">Dark</option>
                            <option value="light">Light (Coming Soon)</option>
                        </select>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-chronicle">
                    <i class="bi bi-check-lg me-1"></i>Save Preferences
                </button>
            </form>
        </div>
        
        <!-- Security Section -->
        <div id="security-section" class="settings-section" style="display: none;">
            <h3 class="settings-section-title"><i class="bi bi-shield-lock me-2"></i>Security</h3>
            
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Password and authentication settings are managed through your identity provider.
            </div>
            
            <div class="mb-3">
                <label class="form-label">Account ID</label>
                <input type="text" class="form-control" value="@Model.CurrentUser.Id" readonly />
                <small class="text-muted">Your unique account identifier</small>
            </div>
        </div>
        
        <!-- Notifications Section -->
        <div id="notifications-section" class="settings-section" style="display: none;">
            <h3 class="settings-section-title"><i class="bi bi-bell me-2"></i>Notifications</h3>
            
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="emailNotifications" checked />
                <label class="form-check-label" for="emailNotifications">Email notifications</label>
            </div>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="campaignUpdates" checked />
                <label class="form-check-label" for="campaignUpdates">Campaign updates</label>
            </div>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="forumReplies" checked />
                <label class="form-check-label" for="forumReplies">Forum replies</label>
            </div>
        </div>
    </div>
</div>

<script>
    function showSection(section) {
        // Hide all sections
        document.querySelectorAll('.settings-section').forEach(s => s.style.display = 'none');
        
        // Remove active from all nav items
        document.querySelectorAll('.settings-nav-item').forEach(n => n.classList.remove('active'));
        
        // Show selected section
        document.getElementById(section + '-section').style.display = 'block';
        
        // Add active to clicked nav item
        event.target.closest('.settings-nav-item').classList.add('active');
    }
</script>