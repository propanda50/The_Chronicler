@page
@model ChroniclerWeb.Pages.Account.ExternalLoginCallbackModel
@{
    ViewData["Title"] = "External Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4 text-center">
                <i class="bi bi-hourglass-split" style="font-size: 3rem; color: var(--chr-gold);"></i>
                <h4 class="mt-3">Completing login...</h4>
                <p class="text-muted">Please wait while we verify your credentials.</p>
                <div class="spinner-border text-warning" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>
