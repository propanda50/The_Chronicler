@page
@model TheChronicler.Web.Pages.Events.CreateModel
@{
    ViewData["Title"] = "New Event";
}

<div class="page-header">
    <h2><i class="bi bi-lightning me-2"></i>New Event</h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.CampaignId" class="entity-link">@Model.CampaignName</a>
    </small>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Event.CampaignId" value="@Model.CampaignId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Event.Title" class="form-label">Event Title</label>
                        <input asp-for="Event.Title" class="form-control" placeholder="The Dragon Awakens" />
                        <span asp-validation-for="Event.Title" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Event.EventDate" class="form-label">Event Date</label>
                            <input asp-for="Event.EventDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Event.SessionId" class="form-label">Associated Session (Optional)</label>
                            <select asp-for="Event.SessionId" class="form-select">
                                <option value="">-- No session --</option>
                                @foreach (var session in Model.AvailableSessions)
                                {
                                    <option value="@session.Id">Session @session.SessionNumber: @session.Title</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Event.Description" class="form-label">Description</label>
                        <textarea asp-for="Event.Description" class="form-control" rows="4" placeholder="Describe what happened..."></textarea>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Event.IsKeyEvent" class="form-check-input" id="isKeyEvent" />
                        <label class="form-check-label" for="isKeyEvent">
                            <i class="bi bi-star-fill me-1" style="color: var(--chr-gold);"></i>Mark as Key Event
                        </label>
                        <div class="text-muted small">Key events are highlighted in the timeline and campaign overview.</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Events/Index" asp-route-campaignId="@Model.CampaignId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Create Event
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
