@page "{id:int}"
@model TheChronicler.Web.Pages.Events.DetailsModel
@{
    ViewData["Title"] = Model.Event.Title;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2>
            @if (Model.Event.IsKeyEvent)
            {
                <i class="bi bi-star-fill me-2" style="color: var(--chr-gold);"></i>
            }
            else
            {
                <i class="bi bi-lightning me-2"></i>
            }
            @Model.Event.Title
        </h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Event.CampaignId" class="entity-link">@Model.CampaignName</a>
            &mdash; <i class="bi bi-calendar me-1"></i>@Model.Event.EventDate.ToString("MMMM dd, yyyy")
        </small>
    </div>
    @if (Model.IsGameMaster)
    {
        <div class="d-flex gap-2">
            <a asp-page="/Events/Edit" asp-route-id="@Model.Event.Id" class="btn btn-outline-chronicle btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-page="/Events/Delete" asp-route-id="@Model.Event.Id" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                @if (Model.Event.IsKeyEvent)
                {
                    <span class="badge badge-key-event mb-3"><i class="bi bi-star-fill me-1"></i>Key Event</span>
                }
                @if (!string.IsNullOrEmpty(Model.Event.Description))
                {
                    <p style="white-space: pre-wrap;">@Model.Event.Description</p>
                }
                else
                {
                    <p class="text-muted">No description provided.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        @if (Model.Event.Session != null)
        {
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Associated Session</h6>
                </div>
                <div class="card-body">
                    <a asp-page="/Sessions/Details" asp-route-id="@Model.Event.SessionId" class="entity-link fw-bold">
                        Session @Model.Event.Session.SessionNumber: @Model.Event.Session.Title
                    </a>
                    <div class="text-muted small mt-1">@Model.Event.Session.SessionDate.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
        }
    </div>
</div>
