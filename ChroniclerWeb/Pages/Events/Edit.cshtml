@page "{id:int}"
@model TheChronicler.Web.Pages.Events.EditModel
@{
    ViewData["Title"] = "Edit Event";
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Edit Event</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Event.Id" />
                    <input type="hidden" asp-for="Event.CampaignId" />
                    <input type="hidden" asp-for="Event.CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Event.Title" class="form-label">Event Title</label>
                        <input asp-for="Event.Title" class="form-control" />
                        <span asp-validation-for="Event.Title" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Event.EventDate" class="form-label">Event Date</label>
                            <input asp-for="Event.EventDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Event.SessionId" class="form-label">Associated Session</label>
                            <select asp-for="Event.SessionId" class="form-select">
                                <option value="">-- No session --</option>
                                @foreach (var session in Model.AvailableSessions)
                                {
                                    <option value="@session.Id">Session @session.SessionNumber: @session.Title</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Event.Description" class="form-label">Description</label>
                        <textarea asp-for="Event.Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Event.IsKeyEvent" class="form-check-input" id="isKeyEvent" />
                        <label class="form-check-label" for="isKeyEvent">
                            <i class="bi bi-star-fill me-1" style="color: var(--chr-gold);"></i>Mark as Key Event
                        </label>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Events/Details" asp-route-id="@Model.Event.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
