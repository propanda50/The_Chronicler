@page "{id:int}"
@model ChroniclerWeb.Pages.Characters.DeleteModel
@{
    ViewData["Title"] = "Delete Character";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card" style="border-color: var(--chr-red);">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-triangle" style="font-size: 3rem; color: var(--chr-red);"></i>
                <h4 class="mt-3">Delete Character</h4>
                <p class="text-muted">
                    Are you sure you want to delete <strong style="color: var(--chr-gold);">@Model.Character.Name</strong>?
                    This will remove them from all session tags.
                </p>
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <a asp-page="/Characters/Details" asp-route-id="@Model.Character.Id" class="btn btn-outline-secondary">Cancel</a>
                    <form method="post">
                        <input type="hidden" asp-for="Character.Id" />
                        <input type="hidden" name="campaignId" value="@Model.Character.CampaignId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
