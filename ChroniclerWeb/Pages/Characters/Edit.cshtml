@page "{id:int}"
@using ChroniclerWeb.Models
@model ChroniclerWeb.Pages.Characters.EditModel
@{
    ViewData["Title"] = "Edit Character";
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Edit Character</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Character.Id" />
                    <input type="hidden" asp-for="Character.CampaignId" />
                    <input type="hidden" asp-for="Character.CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Character.Name" class="form-label">Name</label>
                        <input asp-for="Character.Name" class="form-control" />
                        <span asp-validation-for="Character.Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Character.Type" class="form-label">Type</label>
                            <select asp-for="Character.Type" asp-items="Html.GetEnumSelectList<CharacterType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Character.Status" class="form-label">Status</label>
                            <select asp-for="Character.Status" asp-items="Html.GetEnumSelectList<CharacterStatus>()" class="form-select"></select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Race" class="form-label">Race</label>
                            <input asp-for="Character.Race" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Class" class="form-label">Class</label>
                            <input asp-for="Character.Class" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Role" class="form-label">Role in Campaign</label>
                            <input asp-for="Character.Role" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Character.Description" class="form-label">Description</label>
                        <textarea asp-for="Character.Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Characters/Details" asp-route-id="@Model.Character.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
