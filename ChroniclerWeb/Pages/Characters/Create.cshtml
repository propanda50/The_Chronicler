@page
@model ChroniclerWeb.Pages.Characters.CreateModel
@{
    ViewData["Title"] = "Create Character";
}

<script src="~/js/predefinedLists.js"></script>

<script>
    // Populate predefined lists from server
    @if (!string.IsNullOrEmpty(Model.PredefinedClassesJson))
    {
        <text>
        Object.assign(RPG_CLASSES, @Html.Raw(Model.PredefinedClassesJson));
        </text>
    }
    @if (!string.IsNullOrEmpty(Model.PredefinedRacesJson))
    {
        <text>
        Object.assign(RPG_RACES, @Html.Raw(Model.PredefinedRacesJson));
        </text>
    }
    @if (!string.IsNullOrEmpty(Model.PredefinedRolesJson))
    {
        <text>
        Object.assign(RPG_ROLES, @Html.Raw(Model.PredefinedRolesJson));
        </text>
    }
</script>

<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
    .step-indicator {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 10px;
    }
    .step {
        padding: 10px 25px;
        background: var(--chr-bg-surface);
        border: 1px solid var(--chr-border);
        border-radius: 20px;
        color: var(--chr-text-muted);
        font-size: 0.9rem;
    }
    .step.active {
        background: var(--chr-primary);
        color: white;
        border-color: var(--chr-primary);
    }
    .step.completed {
        background: rgba(16, 185, 129, 0.2);
        color: var(--chr-green);
        border-color: var(--chr-green);
    }
    .stat-row {
        display: flex;
        align-items: center;
        margin-bottom: 16px;
        gap: 12px;
    }
    .stat-name {
        width: 160px;
        min-width: 160px;
        font-weight: 500;
        color: var(--chr-text);
    }
    .stat-slider {
        flex: 1;
        -webkit-appearance: none;
        height: 8px;
        border-radius: 4px;
        background: var(--chr-bg-surface);
        outline: none;
    }
    .stat-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--chr-gold);
        cursor: pointer;
        border: 2px solid white;
    }
    .stat-value {
        width: 50px;
        text-align: center;
        font-weight: bold;
        color: var(--chr-gold);
    }
    .stat-max {
        width: 40px;
        text-align: left;
        color: var(--chr-text-muted);
        font-size: 0.8rem;
    }
    .randomize-btn {
        white-space: nowrap;
        padding: 6px 12px;
        font-size: 0.85rem;
    }
    .loading-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.8);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    .loading-overlay.hidden {
        display: none;
    }
    .spinner {
        width: 60px;
        height: 60px;
        border: 5px solid var(--chr-border);
        border-top-color: var(--chr-gold);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }
    .character-preview {
        border-radius: 16px;
        border: 3px solid var(--chr-gold);
        box-shadow: 0 0 30px rgba(212, 168, 67, 0.3);
    }
    .image-option {
        border: 2px dashed var(--chr-border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background: var(--chr-bg-surface);
    }
    .image-option:hover, .image-option.selected {
        border-color: var(--chr-gold);
        background: rgba(212, 168, 67, 0.1);
    }
    .ai-loading {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid var(--chr-border);
        border-top-color: var(--chr-gold);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-left: 8px;
    }
    .dropdown-item {
        cursor: pointer;
    }
    .dropdown-item:hover {
        background: var(--chr-bg-surface);
    }
    .autocomplete-dropdown {
        position: absolute;
        z-index: 1000;
        max-height: 200px;
        overflow-y: auto;
        background: var(--chr-bg-card);
        border: 1px solid var(--chr-border);
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        display: none;
    }
    .autocomplete-dropdown.show {
        display: block;
    }
    .autocomplete-item {
        padding: 10px 15px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .autocomplete-item:hover {
        background: rgba(139, 92, 246, 0.2);
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-person-plus me-2"></i>Create Character</h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.CampaignId" class="entity-link text-info">@Model.CampaignName</a>
    </small>
</div>

<!-- Step Indicator -->
<div class="step-indicator">
    <div class="step active" id="step1Indicator">1. Basics</div>
    <div class="step" id="step2Indicator">2. Name</div>
    <div class="step" id="step3Indicator">3. Description</div>
    <div class="step" id="step4Indicator">4. Image</div>
</div>

<!-- Loading Overlay -->
<div class="loading-overlay hidden" id="loadingOverlay">
    <div class="spinner mb-3"></div>
    <p class="text-light" id="loadingText">Generating...</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data" id="characterForm">
                    <input type="hidden" name="Character.CampaignId" value="@Model.CampaignId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- STEP 1: Character Basics (Class, Race, Role, Stats) -->
                    <div id="step1">
                        <h5 class="mb-4" style="color: var(--chr-gold);">
                            <i class="bi bi-person-badge me-2"></i>Character Basics
                        </h5>

                        <!-- Race, Class, Role with autocomplete -->
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3 position-relative">
                                <label class="form-label">Race</label>
                                <div class="input-group">
                                    <input asp-for="Character.Race" class="form-control" placeholder="Select or type race..." id="CharacterRace" autocomplete="off" />
                                    <button type="button" class="btn btn-outline-secondary randomize-btn" onclick="randomizeRace()">
                                        <i class="bi bi-shuffle"></i>
                                    </button>
                                </div>
                                <div class="autocomplete-dropdown" id="raceDropdown"></div>
                            </div>
                            <div class="col-md-4 mb-3 position-relative">
                                <label class="form-label">Class</label>
                                <div class="input-group">
                                    <input asp-for="Character.Class" class="form-control" placeholder="Select or type class..." id="CharacterClass" autocomplete="off" />
                                    <button type="button" class="btn btn-outline-secondary randomize-btn" onclick="randomizeClass()">
                                        <i class="bi bi-shuffle"></i>
                                    </button>
                                </div>
                                <div class="autocomplete-dropdown" id="classDropdown"></div>
                            </div>
                            <div class="col-md-4 mb-3 position-relative">
                                <label class="form-label">Role</label>
                                <div class="input-group">
                                    <input asp-for="Character.Role" class="form-control" placeholder="Select or type role..." id="CharacterRole" autocomplete="off" />
                                    <button type="button" class="btn btn-outline-secondary randomize-btn" onclick="randomizeRole()">
                                        <i class="bi bi-shuffle"></i>
                                    </button>
                                </div>
                                <div class="autocomplete-dropdown" id="roleDropdown"></div>
                            </div>
                        </div>

                        <!-- NPC Type and Status -->
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Type</label>
                                <select asp-for="Character.Type" class="form-select" id="CharacterType" onchange="toggleNPCRoles()">
                                    <option value="0">Player Character</option>
                                    <option value="1">NPC</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Status</label>
                                <select asp-for="Character.Status" class="form-select">
                                    <option value="0">Alive</option>
                                    <option value="1">Dead</option>
                                    <option value="2">Undead</option>
                                    <option value="3">Missing</option>
                                    <option value="4">Unknown</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3" id="npcRoleSection" style="display: none;">
                                <label class="form-label">NPC Role</label>
                                <select asp-for="Character.NPCRole" class="form-select">
                                    <option value="0">None</option>
                                    <option value="1">Antagonist</option>
                                    <option value="2">Ally</option>
                                    <option value="3">Merchant</option>
                                    <option value="4">Plot Driver</option>
                                    <option value="5">Quest Giver</option>
                                    <option value="6">Informant</option>
                                    <option value="7">Henchman</option>
                                </select>
                            </div>
                        </div>

                        <!-- Stats Section -->
                        <hr class="chr-divider" />
                        <h5 class="mb-4" style="color: var(--chr-gold);">
                            <i class="bi bi-graph-up me-2"></i>Stats
                            <small class="text-muted ms-3">Points remaining: <span id="pointsRemaining" class="text-warning">60</span> / 60</small>
                        </h5>

                        <!-- Stats and Radar Chart -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="stats-container">
                                    <div class="stat-row">
                                        <span class="stat-name">Strength</span>
                                        <input type="range" class="stat-slider" id="StrengthSlider" min="0" max="20" value="0" oninput="updateStat('Strength', this.value)">
                                        <span class="stat-value" id="StrengthValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Strength" id="Strength" value="0" />
                                    </div>
                                    <div class="stat-row">
                                        <span class="stat-name">Agility</span>
                                        <input type="range" class="stat-slider" id="AgilitySlider" min="0" max="20" value="0" oninput="updateStat('Agility', this.value)">
                                        <span class="stat-value" id="AgilityValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Agility" id="Agility" value="0" />
                                    </div>
                                    <div class="stat-row">
                                        <span class="stat-name">Health</span>
                                        <input type="range" class="stat-slider" id="HealthSlider" min="0" max="20" value="0" oninput="updateStat('Health', this.value)">
                                        <span class="stat-value" id="HealthValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Health" id="Health" value="0" />
                                    </div>
                                    <div class="stat-row">
                                        <span class="stat-name">Intelligence</span>
                                        <input type="range" class="stat-slider" id="IntelligenceSlider" min="0" max="20" value="0" oninput="updateStat('Intelligence', this.value)">
                                        <span class="stat-value" id="IntelligenceValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Intelligence" id="Intelligence" value="0" />
                                    </div>
                                    <div class="stat-row">
                                        <span class="stat-name">Charisma</span>
                                        <input type="range" class="stat-slider" id="CharismaSlider" min="0" max="20" value="0" oninput="updateStat('Charisma', this.value)">
                                        <span class="stat-value" id="CharismaValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Charisma" id="Charisma" value="0" />
                                    </div>
                                    <div class="stat-row">
                                        <span class="stat-name">Endurance</span>
                                        <input type="range" class="stat-slider" id="EnduranceSlider" min="0" max="20" value="0" oninput="updateStat('Endurance', this.value)">
                                        <span class="stat-value" id="EnduranceValue">0</span>
                                        <span class="stat-max">/20</span>
                                        <input type="hidden" asp-for="Character.Endurance" id="Endurance" value="0" />
                                    </div>
                                </div>
                                
                                <!-- Randomize Buttons -->
                                <div class="text-center mt-3">
                                    <button type="button" class="btn btn-outline-chronicle me-2" onclick="generateRandomStats()">
                                        <i class="bi bi-shuffle me-1"></i> Randomize Stats
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="resetStats()">
                                        <i class="bi bi-arrow-clockwise me-1"></i> Reset
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Radar Chart -->
                            <div class="col-md-6">
                                <div class="radar-chart-container text-center">
                                    <canvas id="radarCanvas" width="300" height="300" style="max-width: 100%;"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-chronicle" onclick="goToStep2()">
                                Next <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 2: Character Name -->
                    <div id="step2" style="display: none;">
                        <h5 class="mb-4" style="color: var(--chr-gold);">
                            <i class="bi bi-person-badge me-2"></i>Character Name & Pseudo
                        </h5>
                        
                        <div class="mb-4">
                            <label class="form-label">Full Name</label>
                            <div class="input-group">
                                <input asp-for="Character.Name" class="form-control" placeholder="Enter character full name..." id="CharacterName" />
                                <button type="button" class="btn btn-chronicle" onclick="generateCharacterName()" id="generateNameBtn">
                                    <i class="bi bi-magic me-1"></i> Generate Name
                                </button>
                            </div>
                            <small class="text-muted">AI generates a unique first name + last name based on race, class, and role</small>
                            <span asp-validation-for="Character.Name" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Surname / Pseudo (Optional)</label>
                            <div class="input-group">
                                <input asp-for="Character.Pseudo" class="form-control" placeholder="Enter character pseudo or epithet..." id="CharacterPseudo" />
                                <button type="button" class="btn btn-chronicle" onclick="generateCharacterPseudo()" id="generatePseudoBtn">
                                    <i class="bi bi-magic me-1"></i> Generate Pseudo
                                </button>
                            </div>
                            <small class="text-muted">AI generates a fitting epithet based on class, role, and stats (e.g., "The Iron Blade")</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" onclick="goToStep1()">
                                <i class="bi bi-arrow-left me-1"></i> Previous
                            </button>
                            <button type="button" class="btn btn-chronicle" onclick="goToStep3()">
                                Next <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 3: Character Description -->
                    <div id="step3" style="display: none;">
                        <h5 class="mb-4" style="color: var(--chr-gold);">
                            <i class="bi bi-card-text me-2"></i>Character Description
                        </h5>
                        
                        <div class="mb-4">
                            <label class="form-label">Description</label>
                            <div class="d-flex gap-2 mb-2">
                                <button type="button" class="btn btn-chronicle" onclick="generateCharacterDescription()" id="generateDescBtn">
                                    <i class="bi bi-magic me-1"></i> Generate with AI
                                </button>
                                <button type="button" class="btn btn-outline-secondary" onclick="regenerateDescription()" id="regenerateDescBtn" style="display: none;">
                                    <i class="bi bi-arrow-clockwise me-1"></i> Regenerate
                                </button>
                            </div>
                            <textarea asp-for="Character.Description" class="form-control" rows="6" placeholder="Describe your character's appearance, background, personality..." id="CharacterDescription"></textarea>
                            <small class="text-muted">AI generates 4-6 sentences based on all character details</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" onclick="goToStep2()">
                                <i class="bi bi-arrow-left me-1"></i> Previous
                            </button>
                            <button type="button" class="btn btn-chronicle" onclick="goToStep4()">
                                Next <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 4: Character Image -->
                    <div id="step4" style="display: none;">
                        <h5 class="mb-4" style="color: var(--chr-gold);">
                            <i class="bi bi-image me-2"></i>Character Image
                        </h5>

                        <div class="row mb-4">
                            <div class="col-12">
                                <div class="image-option" id="uploadOption" onclick="document.getElementById('characterImageUpload').click()">
                                    <i class="bi bi-folder2-open fs-1 d-block mb-2" style="color: var(--chr-primary);"></i>
                                    <strong>Upload Image</strong>
                                    <p class="text-muted mb-0 small">PNG, JPG, GIF - Photo or artwork of your character</p>
                                </div>
                                <input type="file" id="characterImageUpload" class="form-control mt-2" accept="image/*" onchange="handleImageUpload(this)" />
                            </div>
                        </div>

                        <!-- Image Preview -->
                        <div class="text-center mb-4" id="imagePreviewContainer" style="display: none;">
                            <img id="characterImagePreview" class="img-fluid character-preview" style="max-height: 400px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);" alt="Character Preview" />
                            <button type="button" class="btn btn-outline-danger mt-2" onclick="removeImage()">
                                <i class="bi bi-trash me-1"></i> Remove
                            </button>
                        </div>

                        <input type="hidden" asp-for="Character.PortraitUrl" id="PortraitUrl" />
                        <input type="hidden" asp-for="Character.PortraitData" id="PortraitData" />
                        <input type="hidden" asp-for="Character.PortraitContentType" id="PortraitContentType" />

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" onclick="goToStep3()">
                                <i class="bi bi-arrow-left me-1"></i> Previous
                            </button>
                            <button type="submit" class="btn btn-chronicle">
                                <i class="bi bi-check-lg me-1"></i> Create Character
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const MAX_POINTS = 60;
        
        // Step Navigation
        function goToStep1() {
            document.getElementById('step1').style.display = 'block';
            document.getElementById('step2').style.display = 'none';
            document.getElementById('step3').style.display = 'none';
            document.getElementById('step4').style.display = 'none';
            updateStepIndicators(1);
        }

        function goToStep2() {
            // Validate step 1
            const race = document.getElementById('CharacterRace').value;
            const charClass = document.getElementById('CharacterClass').value;
            
            if (!race.trim() || !charClass.trim()) {
                alert('Please select or enter Race and Class before proceeding.');
                return;
            }
            
            document.getElementById('step1').style.display = 'none';
            document.getElementById('step2').style.display = 'block';
            document.getElementById('step3').style.display = 'none';
            document.getElementById('step4').style.display = 'none';
            updateStepIndicators(2);
        }

        function goToStep3() {
            // Validate step 2
            const name = document.getElementById('CharacterName').value;
            
            if (!name.trim()) {
                alert('Please enter a name for your character.');
                return;
            }
            
            // Store original AI content for translation
            const currentLang = localStorage.getItem('preferredLanguage') || 'en';
            if (typeof TranslationService !== 'undefined') {
                TranslationService.storeOriginal('characterName', name, currentLang);
                const pseudo = document.getElementById('CharacterPseudo').value;
                if (pseudo) {
                    TranslationService.storeOriginal('characterPseudo', pseudo, currentLang);
                }
            }
            
            document.getElementById('step1').style.display = 'none';
            document.getElementById('step2').style.display = 'none';
            document.getElementById('step3').style.display = 'block';
            document.getElementById('step4').style.display = 'none';
            updateStepIndicators(3);
        }

        function goToStep4() {
            // Store description for translation
            const desc = document.getElementById('CharacterDescription').value;
            const currentLang = localStorage.getItem('preferredLanguage') || 'en';
            if (desc && typeof TranslationService !== 'undefined') {
                TranslationService.storeOriginal('characterDescription', desc, currentLang);
            }
            
            document.getElementById('step1').style.display = 'none';
            document.getElementById('step2').style.display = 'none';
            document.getElementById('step3').style.display = 'none';
            document.getElementById('step4').style.display = 'block';
            updateStepIndicators(4);
        }

        function updateStepIndicators(currentStep) {
            for (let i = 1; i <= 4; i++) {
                const el = document.getElementById('step' + i + 'Indicator');
                if (i < currentStep) {
                    el.className = 'step completed';
                } else if (i === currentStep) {
                    el.className = 'step active';
                } else {
                    el.className = 'step';
                }
            }
        }

        // Stats Management
        function updateStat(stat, value) {
            let val = parseInt(value);
            let used = 0;
            
            ['Strength', 'Agility', 'Health', 'Intelligence', 'Charisma', 'Endurance'].forEach(s => {
                if (s !== stat) {
                    used += parseInt(document.getElementById(s).value) || 0;
                }
            });
            
            const remaining = MAX_POINTS - used;
            
            if (val > remaining) {
                val = Math.max(0, remaining);
            }
            
            val = Math.max(0, val);
            
            document.getElementById(stat).value = val;
            document.getElementById(stat + 'Value').textContent = val;
            document.getElementById(stat + 'Slider').value = val;
            calculateUsedPoints();
            updateRadarChart();
        }

        function calculateUsedPoints() {
            let used = 0;
            ['Strength', 'Agility', 'Health', 'Intelligence', 'Charisma', 'Endurance'].forEach(stat => {
                used += parseInt(document.getElementById(stat).value) || 0;
            });
            const remaining = MAX_POINTS - used;
            document.getElementById('pointsRemaining').textContent = remaining;
            
            const pointsEl = document.getElementById('pointsRemaining');
            if (remaining < 0) {
                pointsEl.className = 'text-danger';
            } else if (remaining === 0) {
                pointsEl.className = 'text-success';
            } else {
                pointsEl.className = 'text-warning';
            }
        }

        function generateRandomStats() {
            let points = MAX_POINTS;
            const stats = ['Strength', 'Agility', 'Health', 'Intelligence', 'Charisma', 'Endurance'];
            const values = [];
            
            for (let i = 0; i < stats.length; i++) {
                if (i === stats.length - 1) {
                    values[i] = points;
                } else {
                    const maxForThis = Math.min(points - (stats.length - i - 1), 20);
                    const minForThis = Math.max(0, points - 20 * (stats.length - i - 1));
                    values[i] = Math.floor(Math.random() * (maxForThis - minForThis + 1)) + minForThis;
                }
                points -= values[i];
            }
            
            // Shuffle
            for (let i = values.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [values[i], values[j]] = [values[j], values[i]];
            }
            
            stats.forEach((stat, idx) => {
                document.getElementById(stat).value = values[idx];
                document.getElementById(stat + 'Value').textContent = values[idx];
                document.getElementById(stat + 'Slider').value = values[idx];
            });
            
            calculateUsedPoints();
            updateRadarChart();
        }

        function resetStats() {
            ['Strength', 'Agility', 'Health', 'Intelligence', 'Charisma', 'Endurance'].forEach(stat => {
                document.getElementById(stat).value = 0;
                document.getElementById(stat + 'Value').textContent = 0;
                document.getElementById(stat + 'Slider').value = 0;
            });
            calculateUsedPoints();
            updateRadarChart();
