        function _charDict() { return _CD[(localStorage.getItem('preferredLanguage')||'en').split('-')[0]] || _CD.en; }
        function _pick(a) { return a[Math.floor(Math.random()*a.length)]; }

        function randomizeRace() {
            var races = ['Human','Elf','Dwarf','Orc','Halfling','Tiefling','Dragonborn','Gnome'];
            document.getElementById('CharacterRace').value = _pick(races);
        }

        function randomizeClass() {
            var classes = ['Fighter','Wizard','Rogue','Cleric','Paladin','Ranger','Barbarian','Bard','Druid','Monk','Sorcerer','Warlock'];
            document.getElementById('CharacterClass').value = _pick(classes);
        }

        function randomizeRole() {
            var roles = ['None','Ally','Antagonist','Merchant','Quest Giver','Informant','Henchman'];
            document.getElementById('CharacterRole').value = _pick(roles);
        }

        function generateCharacterName() {
            var d = _charDict();
            var race = (document.getElementById('CharacterRace').value || 'human').toLowerCase();
            var firsts = d[race] || d.human;
            var name = _pick(firsts) + ' ' + _pick(d.last);
            document.getElementById('CharacterName').value = name;
        }

        function generateCharacterPseudo() {
            var d = _charDict();
            var cls = (document.getElementById('CharacterClass').value || 'fighter').toLowerCase();
            var list = d.pseudo[cls] || d.pseudo.fighter;
            document.getElementById('CharacterPseudo').value = _pick(list);
        }

        function generateCharacterDescription() {
            var d = _charDict();
            var race = document.getElementById('CharacterRace').value || 'Human';
            var cls = document.getElementById('CharacterClass').value || 'Fighter';
            var pseudo = document.getElementById('CharacterPseudo').value || '';
            var name = document.getElementById('CharacterName').value || _pick(d.human) + ' ' + _pick(d.last);
            var bg = _pick(d.bg);
            var story = _pick(d.story);
            
            // Build description with race and class included
            var desc = race + ' ' + cls + ' - ' + name;
            if (pseudo) desc += ' "' + pseudo + '"';
            desc += '. ';
            desc += bg + '. ';
            desc += story + '.';
            document.getElementById('CharacterDescription').value = desc;
        }

        function regenerateDescription() {
            generateCharacterDescription();
        }

        // Radar Chart
        function updateRadarChart() {
            const canvas = document.getElementById('radarCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = Math.min(centerX, centerY) - 30;
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const stats = ['Strength', 'Agility', 'Health', 'Intelligence', 'Charisma', 'Endurance'];
            const values = stats.map(s => parseInt(document.getElementById(s).value) || 0);
            const numStats = stats.length;
            const angleStep = (2 * Math.PI) / numStats;
            
            const statLabels = stats;
            
            // Draw spiderweb grid
            const levels = 5;
            ctx.strokeStyle = 'rgba(139, 92, 246, 0.3)';
            ctx.lineWidth = 1;
            
            for (let level = 1; level <= levels; level++) {
                const levelRadius = (radius / levels) * level;
                ctx.beginPath();
                for (let i = 0; i <= numStats; i++) {
                    const angle = i * angleStep - Math.PI / 2;
                    const x = centerX + levelRadius * Math.cos(angle);
                    const y = centerY + levelRadius * Math.sin(angle);
                    if (i === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                }
                ctx.closePath();
                ctx.stroke();
            }
            
            // Draw axes
            ctx.strokeStyle = 'rgba(139, 92, 246, 0.5)';
            for (let i = 0; i < numStats; i++) {
                const angle = i * angleStep - Math.PI / 2;
                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.lineTo(centerX + radius * Math.cos(angle), centerY + radius * Math.sin(angle));
                ctx.stroke();
            }
            
            // Draw labels
            ctx.fillStyle = '#d4a843';
            ctx.font = 'bold 10px Arial';
            ctx.textAlign = 'center';
            for (let i = 0; i < numStats; i++) {
                const angle = i * angleStep - Math.PI / 2;
                const labelRadius = radius + 18;
                const x = centerX + labelRadius * Math.cos(angle);
                const y = centerY + labelRadius * Math.sin(angle);
                ctx.fillText(statLabels[i], x, y + 4);
            }
            
            // Draw data polygon
            ctx.beginPath();
            for (let i = 0; i <= numStats; i++) {
                const idx = i % numStats;
                const angle = idx * angleStep - Math.PI / 2;
                const value = values[idx];
                const valueRadius = (value / 20) * radius;
                const x = centerX + valueRadius * Math.cos(angle);
                const y = centerY + valueRadius * Math.sin(angle);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.closePath();
            
            const gradient = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, radius);
            gradient.addColorStop(0, 'rgba(139, 92, 246, 0.5)');
            gradient.addColorStop(1, 'rgba(212, 168, 67, 0.3)');
            ctx.fillStyle = gradient;
            ctx.fill();
            
            ctx.strokeStyle = '#d4a843';
            ctx.lineWidth = 2;
            ctx.stroke();
            
            // Draw points
            for (let i = 0; i < numStats; i++) {
                const angle = i * angleStep - Math.PI / 2;
                const value = values[i];
                const valueRadius = (value / 20) * radius;
                const x = centerX + valueRadius * Math.cos(angle);
                const y = centerY + valueRadius * Math.sin(angle);
                
                ctx.beginPath();
                ctx.arc(x, y, 5, 0, 2 * Math.PI);
                ctx.fillStyle = '#d4a843';
                ctx.fill();
                ctx.strokeStyle = '#fff';
                ctx.lineWidth = 2;
                ctx.stroke();
            }
        }

        // Toggle NPC Roles
        function toggleNPCRoles() {
            const type = document.getElementById('CharacterType').value;
            document.getElementById('npcRoleSection').style.display = type === '1' ? 'block' : 'none';
        }

        // Image handling using ImageProcessor
        async function handleImageUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                
                if (!ImageProcessor.isValidImage(file)) {
                    alert('Please select a valid image file (JPEG, PNG, GIF, or WebP)');
                    return;
                }
                
                try {
                    showLoading('Processing image...');
                    
                    const result = await ImageProcessor.processImage(file, {
                        maxWidth: 1024,
                        maxHeight: 1024,
                        quality: 0.85,
                        contentType: 'image/jpeg',
                        cropToSquare: false
                    });
                    
                    ImageProcessor.showPreview('imagePreviewContainer', 'characterImagePreview', result.dataUrl);
                    
                    document.getElementById('PortraitUrl').value = '';
                    document.getElementById('PortraitData').value = result.base64;
                    document.getElementById('PortraitContentType').value = result.contentType;
                    
                    hideLoading();
                } catch (error) {
                    hideLoading();
                    alert('Error processing image: ' + error.message);
                }
            }
        }

        function removeImage() {
            ImageProcessor.clearPreview('imagePreviewContainer', 'characterImagePreview');
            document.getElementById('PortraitUrl').value = '';
            document.getElementById('PortraitData').value = '';
            document.getElementById('PortraitContentType').value = '';
            document.getElementById('characterImageUpload').value = '';
        }

        // Loading overlay
        function showLoading(text) {
            document.getElementById('loadingText').textContent = text;
            document.getElementById('loadingOverlay').classList.remove('hidden');
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').classList.add('hidden');
        }

    // Autocomplete functionality
    function setupAutocomplete(inputId, dropdownId, itemsObj, onSelect) {
        const input = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);
        
        input.addEventListener('input', debounce(function() {
            const value = this.value.toLowerCase();
            if (value.length < 1) {
                dropdown.classList.remove('show');
                return;
            }
            
            // Get localized strings
            const items = Object.keys(itemsObj).map(k => {
                return { key: k, text: getLocalizedValue(itemsObj, k) };
            });
            
            const matches = items.filter(item => item.text.toLowerCase().includes(value)).slice(0, 10);
            
            if (matches.length > 0) {
                dropdown.innerHTML = matches.map(item => 
                    `<div class="autocomplete-item" onclick="selectAutocomplete('${inputId}', '${dropdownId}', '${item.text}', '${item.key}')">${item.text}</div>`
                ).join('');
                dropdown.classList.add('show');
            } else {
                dropdown.classList.remove('show');
            }
        }, 200));
        
        input.addEventListener('blur', () => {
            setTimeout(() => dropdown.classList.remove('show'), 200);
        });
    }

    function selectAutocomplete(inputId, dropdownId, value, rawKey) {
        const input = document.getElementById(inputId);
        input.value = value;
        input.dataset.rawKey = rawKey;
        document.getElementById(dropdownId).classList.remove('show');
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        calculateUsedPoints();
        updateRadarChart();
        
        // Setup autocomplete
        if (typeof RPG_RACES !== 'undefined' && Object.keys(RPG_RACES).length > 0) {
            setupAutocomplete('CharacterRace', 'raceDropdown', RPG_RACES);
        }
        if (typeof RPG_CLASSES !== 'undefined' && Object.keys(RPG_CLASSES).length > 0) {
            setupAutocomplete('CharacterClass', 'classDropdown', RPG_CLASSES);
        }
        if (typeof RPG_ROLES !== 'undefined' && Object.keys(RPG_ROLES).length > 0) {
            setupAutocomplete('CharacterRole', 'roleDropdown', RPG_ROLES);
        }
    });
    </script>
