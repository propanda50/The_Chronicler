@page
@model TheChronicler.Web.Pages.Characters.CreateModel
@{
    ViewData["Title"] = "New Character";
}

<div class="page-header">
    <h2><i class="bi bi-person-plus me-2"></i>New Character</h2>
    <small class="text-muted">
        <a asp-page="/Campaigns/Details" asp-route-id="@Model.CampaignId" class="entity-link text-info">@Model.CampaignName</a>
    </small>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" name="Character.CampaignId" value="@Model.CampaignId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row">
    <div class="col-md-8 mb-3">
        <label asp-for="Character.Name" class="form-label">Name</label>
        <div class="input-group">
            <input asp-for="Character.Name" class="form-control" placeholder="Gandalf the Grey" id="CharacterName" />
            <button type="button" class="btn btn-outline-secondary" onclick="generateRandomName()">
                <i class="bi bi-shuffle"></i> Random
            </button>
        </div>
        <span asp-validation-for="Character.Name" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label class="form-label">AI Portrait (Mandatory)</label>
        <div class="text-center">
            <img id="portraitPreview" src="https://api.dicebear.com/7.x/adventurer/svg?seed=default&backgroundColor=b6e3f4" 
                 alt="Character Portrait" class="img-fluid rounded" style="width: 200px; height: 200px; object-fit: cover; border: 3px solid var(--chr-primary);">
            <div class="mt-3">
                <button type="button" class="btn btn-chronicle btn-sm" onclick="generateRandomPortrait()">
                    <i class="bi bi-shuffle"></i> Generate New Portrait
                </button>
            </div>
            <input type="hidden" asp-for="Character.PortraitUrl" id="PortraitUrl" />
            <input type="hidden" asp-for="Character.PortraitData" id="PortraitData" />
            <input type="hidden" asp-for="Character.PortraitContentType" id="PortraitContentType" />
        </div>
        <small class="text-muted d-block mt-2">Every character gets a unique AI-generated portrait</small>
    </div>
</div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Type" class="form-label">Type</label>
                            <select asp-for="Character.Type" class="form-select" id="CharacterType" onchange="toggleNPCRoles()">
                                <option value="0">Player</option>
                                <option value="1">NPC</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3" id="npcRoleSection" style="display:none;">
                            <label class="form-label">NPC Role</label>
                            <select asp-for="Character.NPCRole" class="form-select">
                                <option value="0">None</option>
                                <option value="1">Antagonist</option>
                                <option value="2">Ally</option>
                                <option value="3">Merchant</option>
                                <option value="4">Plot Driver</option>
                                <option value="5">Quest Giver</option>
                                <option value="6">Informant</option>
                                <option value="7">Henchman</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Status" class="form-label">Status</label>
                            <select asp-for="Character.Status" class="form-select">
                                <option value="0">Alive</option>
                                <option value="1">Dead</option>
                                <option value="2">Undead</option>
                                <option value="3">Missing</option>
                                <option value="4">Unknown</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Race" class="form-label">Race</label>
                            <div class="input-group">
                                <input asp-for="Character.Race" class="form-control" placeholder="Human, Elf, Dwarf..." id="CharacterRace" />
                                <button type="button" class="btn btn-outline-secondary" onclick="generateRandomRace()">
                                    <i class="bi bi-shuffle"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Class" class="form-label">Class</label>
                            <div class="input-group">
                                <input asp-for="Character.Class" class="form-control" placeholder="Wizard, Fighter..." id="CharacterClass" />
                                <button type="button" class="btn btn-outline-secondary" onclick="generateRandomClass()">
                                    <i class="bi bi-shuffle"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Character.Role" class="form-label">Role (optional)</label>
                            <input asp-for="Character.Role" class="form-control" placeholder="Mentor, Quest Giver..." />
                        </div>
                    </div>

<hr class="chr-divider" />
<h5 class="mb-3" style="color: var(--chr-gold);">
    <i class="bi bi-graph-up me-1"></i>Statistics
    <small class="text-muted ms-2">Points remaining: <span id="pointsRemaining" class="text-warning">54</span> / 54 (Total used: <span id="totalUsed">0</span>)</small>
</h5>

<!-- Stats Input Section -->
<div class="row">
    <div class="col-md-3 mb-2">
        <label class="form-label text-center d-block">Strength</label>
        <div class="input-group">
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Strength', -1)">-</button>
            <input asp-for="Character.Strength" class="form-control text-center stat-input" id="Strength" readonly />
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Strength', 1)">+</button>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <label class="form-label text-center d-block">Agility</label>
        <div class="input-group">
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Agility', -1)">-</button>
            <input asp-for="Character.Agility" class="form-control text-center stat-input" id="Agility" readonly />
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Agility', 1)">+</button>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <label class="form-label text-center d-block">Health</label>
        <div class="input-group">
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Health', -1)">-</button>
            <input asp-for="Character.Health" class="form-control text-center stat-input" id="Health" readonly />
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Health', 1)">+</button>
        </div>
    </div>
    <div class="col-md-3 mb-2">
        <label class="form-label text-center d-block">Intelligence</label>
        <div class="input-group">
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Intelligence', -1)">-</button>
            <input asp-for="Character.Intelligence" class="form-control text-center stat-input" id="Intelligence" readonly />
            <button type="button" class="btn btn-outline-secondary" onclick="adjustStat('Intelligence', 1)">+</button>
        </div>
    </div>
</div>

<!-- Radar Chart Section -->
<div class="radar-chart-container mt-4">
    <h6 class="text-center mb-3" style="color: var(--chr-primary);">Stat Distribution</h6>
    <div class="radar-chart">
        <div class="radar-grid">
            <!-- Concentric circles -->
            <div class="radar-circle" style="--size: 20%;"></div>
            <div class="radar-circle" style="--size: 40%;"></div>
            <div class="radar-circle" style="--size: 60%;"></div>
            <div class="radar-circle" style="--size: 80%;"></div>
            <div class="radar-circle" style="--size: 100%;"></div>
            
            <!-- Axes -->
            <div class="radar-axis" style="--angle: 0deg;">
                <div class="axis-label">Strength</div>
            </div>
            <div class="radar-axis" style="--angle: 90deg;">
                <div class="axis-label">Agility</div>
            </div>
            <div class="radar-axis" style="--angle: 180deg;">
                <div class="axis-label">Health</div>
            </div>
            <div class="radar-axis" style="--angle: 270deg;">
                <div class="axis-label">Intelligence</div>
            </div>
        </div>
        
        <!-- Stat Plot -->
        <div class="radar-plot">
            <div class="radar-point" id="strengthPoint" style="--value: 5; --angle: 0deg;"></div>
            <div class="radar-point" id="agilityPoint" style="--value: 5; --angle: 90deg;"></div>
            <div class="radar-point" id="healthPoint" style="--value: 5; --angle: 180deg;"></div>
            <div class="radar-point" id="intelligencePoint" style="--value: 5; --angle: 270deg;"></div>
            
            <!-- Connect points -->
            <div class="radar-area" id="radarArea"></div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-12 text-center">
        <button type="button" class="btn btn-outline-chronicle" onclick="generateRandomStats()">
            <i class="bi bi-shuffle me-1"></i> Random Stats
        </button>
        <button type="button" class="btn btn-outline-secondary" onclick="resetStats()">
            <i class="bi bi-arrow-clockwise me-1"></i> Reset to 5
        </button>
    </div>

                    <hr class="chr-divider" />

                    <div class="mb-3">
                        <label asp-for="Character.Description" class="form-label">Description</label>
                        <textarea asp-for="Character.Description" class="form-control" rows="3" placeholder="Describe this character..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Character.SharedNotes" class="form-label">Shared Notes (everyone can see)</label>
                            <textarea asp-for="Character.SharedNotes" class="form-control" rows="3" placeholder="Visible to all players..."></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Character.GMNotes" class="form-label">GM Notes (only GM can see)</label>
                            <textarea asp-for="Character.GMNotes" class="form-control" rows="3" placeholder="Private notes..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="/Characters/Index" asp-route-campaignId="@Model.CampaignId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-chronicle">
                            <i class="bi bi-check-lg me-1"></i>Create Character
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const MAX_POINTS = 54;
        const BASE_STAT = 0;
        const MAX_STAT = 18;
        let usedPoints = 0;

        function calculateUsedPoints() {
            usedPoints = 0;
            ['Strength', 'Agility', 'Health', 'Intelligence'].forEach(stat => {
                const val = parseInt(document.getElementById(stat).value) || 0;
                usedPoints += val;
            });
            document.getElementById('pointsRemaining').textContent = MAX_POINTS - usedPoints;
            document.getElementById('totalUsed').textContent = usedPoints;
        }

        function adjustStat(stat, delta) {
            const input = document.getElementById(stat);
            let val = parseInt(input.value) || 0;
            const newVal = val + delta;
            
            if (newVal >= 0 && newVal <= MAX_STAT) {
                let total = 0;
                ['Strength', 'Agility', 'Health', 'Intelligence'].forEach(s => {
                    if (s === stat) {
                        total += newVal;
                    } else {
                        total += parseInt(document.getElementById(s).value) || 0;
                    }
                });
                
                if (total <= MAX_POINTS || delta < 0) {
                    input.value = newVal;
                    calculateUsedPoints();
                    updateRadarChart();
                }
            }
        }

        function updateRadarChart() {
            // Get stat values (1-20 range)
            const strength = parseInt(document.getElementById('Strength').value) || 5;
            const agility = parseInt(document.getElementById('Agility').value) || 5;
            const health = parseInt(document.getElementById('Health').value) || 5;
            const intelligence = parseInt(document.getElementById('Intelligence').value) || 5;
            
            // Convert to percentage of max (20) for radar chart
            const maxStat = 20;
            const strengthPct = (strength / maxStat) * 100;
            const agilityPct = (agility / maxStat) * 100;
            const healthPct = (health / maxStat) * 100;
            const intelligencePct = (intelligence / maxStat) * 100;
            
            // Update point positions
            document.getElementById('strengthPoint').style.setProperty('--value', strengthPct);
            document.getElementById('agilityPoint').style.setProperty('--value', agilityPct);
            document.getElementById('healthPoint').style.setProperty('--value', healthPct);
            document.getElementById('intelligencePoint').style.setProperty('--value', intelligencePct);
        }

        function toggleNPCRoles() {
            const type = document.getElementById('CharacterType').value;
            const npcSection = document.getElementById('npcRoleSection');
            npcSection.style.display = type === '1' ? 'block' : 'none';
        }

        async function generateRandomName() {
            // Get current race and class to generate appropriate name
            const race = document.getElementById('CharacterRace').value;
            const characterClass = document.getElementById('CharacterClass').value;
            
            // Name arrays for different races - only used for fallback
            const humanNames = ['Aldric', 'Brenna', 'Cedric', 'Dara', 'Eldric', 'Freya', 'Gareth', 'Helena', 'Idris', 'Jasmine', 'Kael', 'Luna', 'Magnus', 'Nadia', 'Orion', 'Rowan', 'Soren', 'Thalia', 'Wren', 'Zephyr'];
            const elfNames = ['Aelindra', 'Caelum', 'Eryndor', 'Faelyn', 'Galadriel', 'Ilrath', 'Laethiel', 'Miriel', 'Nimrodel', 'Silvanus', 'Thranduil', 'Arwen'];
            const dwarfNames = ['Balin', 'Dwalin', 'Fili', 'Gimli', 'Kili', 'Thorin', 'Durin', 'Gloin', 'Oin', 'Bofur', 'Bombur', 'Nori'];
            const orcNames = ['Grom', 'Thrash', 'Ugluk', 'Mogul', 'Gashnak', 'Grishnak', 'Lurtz', 'Bolg', 'Azog', 'Boldog'];
            const halflingNames = ['Pippin', 'Merry', 'Frodo', 'Sam', 'Bilbo', 'Rosie', 'Hamfast', 'Meriadoc'];
            const tieflingNames = ['Morrigan', 'Raziel', 'Lilith', 'Dante', 'Aurora', 'Zariel', 'Mephistopheles'];
            const dragonbornNames = ['Arjhan', 'Balasar', 'Bharash', 'Donaar', 'Ghesh', 'Heskan', 'Kriv', 'Medrash', 'Nala'];
            
            const lastNames = ['Blackwood', 'Stormwind', 'Ironforge', 'Shadowmere', 'Brightblade', 'Frostborn', 'Moonwhisper', 'Stoneheart', 'Thornwood', 'Dragonbane', 'Silvermist', 'Goldweaver'];
            
            try {
                // Call the AI generator service to generate a name
                const response = await fetch('/AIGenerator/GenerateName', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ race: race, characterClass: characterClass })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.name) {
                        document.getElementById('CharacterName').value = data.name;
                        return;
                    }
                }
            } catch (error) {
                console.log('Using fallback name generator');
            }
            
            // Fallback to traditional random name generation
            let firstNames = humanNames;
            if (race) {
                if (race.toLowerCase().includes('elf') || race.toLowerCase().includes('elven')) {
                    firstNames = elfNames;
                } else if (race.toLowerCase().includes('dwarf') || race.toLowerCase().includes('dwarven')) {
                    firstNames = dwarfNames;
                } else if (race.toLowerCase().includes('orc') || race.toLowerCase().includes('half-orc')) {
                    firstNames = orcNames;
                } else if (race.toLowerCase().includes('halfling') || race.toLowerCase().includes('hobbit')) {
                    firstNames = halflingNames;
                } else if (race.toLowerCase().includes('tiefling')) {
                    firstNames = tieflingNames;
                } else if (race.toLowerCase().includes('dragonborn')) {
                    firstNames = dragonbornNames;
                }
            }
            
            const firstName = firstNames[Math.floor(Math.random() * firstNames.length)];
            const lastName = lastNames[Math.floor(Math.random() * lastNames.length)];
            document.getElementById('CharacterName').value = firstName + ' ' + lastName;
        }

        function generateRandomRace() {
            const races = ['Human', 'Elf', 'Dwarf', 'Halfling', 'Orc', 'Tiefling', 'Dragonborn', 'Gnome', 'Half-Elf', 'Half-Orc'];
            document.getElementById('CharacterRace').value = races[Math.floor(Math.random() * races.length)];
        }

        function generateRandomClass() {
            const classes = ['Fighter', 'Wizard', 'Rogue', 'Cleric', 'Paladin', 'Ranger', 'Barbarian', 'Bard', 'Druid', 'Monk', 'Sorcerer', 'Warlock'];
            document.getElementById('CharacterClass').value = classes[Math.floor(Math.random() * classes.length)];
        }

        function generateRandomStats() {
            // Distribute 54 points across 4 stats (Strength, Agility, Health, Intelligence)
            // Each stat starts at 0 and can go up to 18
            const stats = ['Strength', 'Agility', 'Health', 'Intelligence'];
            
            // Give each stat the base value
            stats.forEach(stat => {
                document.getElementById(stat).value = 0;
            });
            
            // Distribute 54 points randomly
            let remainingPoints = MAX_POINTS;
            while (remainingPoints > 0) {
                const randomStat = stats[Math.floor(Math.random() * stats.length)];
                const currentVal = parseInt(document.getElementById(randomStat).value);
                if (currentVal < MAX_STAT) {
                    document.getElementById(randomStat).value = currentVal + 1;
                    remainingPoints--;
                }
            }
            
            calculateUsedPoints();
            updateRadarChart();
        }

        async function generateRandomPortrait() {
            // Generate a unique seed for the portrait
            const seed = Math.random().toString(36).substring(7);
            const race = document.getElementById('CharacterRace').value || 'fantasy';
            const characterClass = document.getElementById('CharacterClass').value || 'warrior';
            
            try {
                // Try Ollama image generation first
                const response = await fetch('/AIGenerator/GeneratePortrait', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        race: race, 
                        characterClass: characterClass,
                        seed: seed 
                    })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.imageUrl) {
                        document.getElementById('portraitPreview').src = data.imageUrl;
                        document.getElementById('PortraitUrl').value = data.imageUrl;
                        return;
                    }
                }
            } catch (error) {
                console.log('Using DiceBear fallback for portrait');
            }
            
            // Fallback to DiceBear
            const portraitUrl = `https://api.dicebear.com/7.x/adventurer/svg?seed=${seed}&backgroundColor=b6e3f4`;
            document.getElementById('portraitPreview').src = portraitUrl;
            document.getElementById('PortraitUrl').value = portraitUrl;
        }
            try {
                // Call the AI service to generate a character portrait
                const response = await fetch('/AiChat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'message=generate character portrait fantasy RPG'
                });
                
                if (response.ok) {
                    const result = await response.text();
                    // For now, we'll continue with the dicebear service but note that 
                    // in a full implementation, this would use Ollama for image generation
                    const seed = Math.random().toString(36).substring(7);
                    const portraitUrl = `https://api.dicebear.com/7.x/adventurer/svg?seed=${seed}&backgroundColor=b6e3f4`;
                    document.getElementById('portraitPreview').src = portraitUrl;
                    document.getElementById('PortraitUrl').value = portraitUrl;
                    
                    // Show a success message
                    alert('AI-generated portrait created! (Note: Full Ollama image integration coming soon)');
                } else {
                    throw new Error('Failed to generate portrait');
                }
            } catch (error) {
                console.error('Error generating portrait:', error);
                // Fallback to dicebear
                const seed = Math.random().toString(36).substring(7);
                const portraitUrl = `https://api.dicebear.com/7.x/adventurer/svg?seed=${seed}&backgroundColor=b6e3f4`;
                document.getElementById('portraitPreview').src = portraitUrl;
                document.getElementById('PortraitUrl').value = portraitUrl;
            }
        }

        function resetStats() {
            ['Strength', 'Agility', 'Health', 'Intelligence'].forEach(stat => {
                document.getElementById(stat).value = 0;
            });
            calculateUsedPoints();
            updateRadarChart();
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Set initial values to 0
            ['Strength', 'Agility', 'Health', 'Intelligence'].forEach(stat => {
                document.getElementById(stat).value = 0;
            });
            calculateUsedPoints();
            updateRadarChart();
        });
    </script>
}
