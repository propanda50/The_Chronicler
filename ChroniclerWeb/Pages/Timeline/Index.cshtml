@page
@model ChroniclerWeb.Pages.Timeline.IndexModel
@{
    ViewData["Title"] = "Timeline - " + Model.Campaign.Name;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-clock-history me-2"></i>Campaign Timeline</h2>
        <small class="text-muted">
            <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="entity-link">@Model.Campaign.Name</a>
            &mdash; @Model.Sessions.Count sessions, @Model.KeyEvents.Count key events
        </small>
    </div>
    <a asp-page="/Campaigns/Details" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Campaign
    </a>
</div>

@if (Model.TimelineEntries.Any())
{
    <!-- Key Events Summary -->
    @if (Model.KeyEvents.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-star-fill me-2" style="color: var(--chr-gold);"></i>Key Events</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var evt in Model.KeyEvents)
                    {
                        <a href="#event-@evt.Id" class="badge badge-key-event text-decoration-none" style="font-size: 0.85rem; padding: 0.5rem 0.75rem;">
                            <i class="bi bi-star-fill me-1"></i>@evt.Title
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Timeline -->
    <div class="timeline">
        @foreach (var entry in Model.TimelineEntries)
        {
            @if (entry.Type == "session")
            {
                <div class="timeline-item @(entry.HasKeyEvent ? "key-event" : "")">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="text-muted small mb-1">
                                        <i class="bi bi-calendar me-1"></i>@entry.Date.ToString("MMMM dd, yyyy")
                                    </div>
                                    <h5 class="mb-1">
                                        <i class="bi bi-journal-text me-1" style="color: var(--chr-blue);"></i>
                                        <a asp-page="/Sessions/Details" asp-route-id="@entry.Id" class="entity-link">
                                            Session @entry.SessionNumber: @entry.Title
                                        </a>
                                    </h5>
                                    @if (!string.IsNullOrEmpty(entry.Summary))
                                    {
                                        <p class="text-muted mb-2">@entry.Summary</p>
                                    }

                                    <!-- Characters in this session -->
                                    @if (entry.Characters.Any())
                                    {
                                        <div class="mb-1">
                                            <small class="text-muted"><i class="bi bi-people me-1"></i></small>
                                            @foreach (var ch in entry.Characters)
                                            {
                                                <a asp-page="/Characters/Details" asp-route-id="@ch.Id" class="badge bg-secondary text-decoration-none me-1">@ch.Name</a>
                                            }
                                        </div>
                                    }

                                    <!-- Locations in this session -->
                                    @if (entry.Locations.Any())
                                    {
                                        <div class="mb-1">
                                            <small class="text-muted"><i class="bi bi-geo-alt me-1"></i></small>
                                            @foreach (var loc in entry.Locations)
                                            {
                                                <a asp-page="/Locations/Details" asp-route-id="@loc.Id" class="badge bg-secondary text-decoration-none me-1">@loc.Name</a>
                                            }
                                        </div>
                                    }

                                    <!-- Events in this session -->
                                    @if (entry.Events.Any())
                                    {
                                        <div class="mt-2">
                                            @foreach (var evt in entry.Events)
                                            {
                                                <div class="d-flex align-items-center mb-1" id="event-@evt.Id">
                                                    @if (evt.IsKeyEvent)
                                                    {
                                                        <i class="bi bi-star-fill me-2" style="color: var(--chr-gold); font-size: 0.8rem;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-dot me-1"></i>
                                                    }
                                                    <a asp-page="/Events/Details" asp-route-id="@evt.Id" class="entity-link small">@evt.Title</a>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (entry.HasKeyEvent)
                                {
                                    <span class="badge badge-key-event"><i class="bi bi-star-fill"></i></span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-clock-history d-block"></i>
        <h5>No Timeline Data</h5>
        <p>Record sessions and events to build your campaign timeline.</p>
    </div>
}
